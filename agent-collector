# 7. Domain Info (USING THE UNIVERSAL RESOLVER)
if _run_section "domain_info"; then
echo "===SECTION:domain_info==="
if [[ -n "$DOMAIN" ]]; then
    DOCROOT=$(resolve_docroot "$DOMAIN")
    if [[ -n "$DOCROOT" && -d "$DOCROOT" ]]; then inspect_domain "$DOMAIN" "$DOCROOT"
    else echo "domain=$DOMAIN"; echo "document_root=not_found"; fi
elif [[ -n "$OWNER" ]]; then
    echo "mode=auto_discover"; echo "owner=$OWNER"; _found=0
    while IFS= read -r _entry; do
        [[ -z "$_entry" ]] && continue
        if [[ "$_entry" == *"|"* ]]; then
            _dname="${_entry%%|*}"; _dpath="${_entry##*|}"
            if [[ -d "$_dpath" ]]; then inspect_domain "$_dname" "$_dpath"; _found=$((_found + 1)); fi
        else
            _dr=$(resolve_docroot "$_entry")
            if [[ -n "$_dr" && -d "$_dr" ]]; then inspect_domain "$_entry" "$_dr"; _found=$((_found + 1))
            else echo "---domain:${_entry}---"; echo "document_root=not_found"; fi
        fi
    done < <(discover_account_domains "$OWNER")
    echo "domains_found=$_found"
else
    echo "mode=all_accounts"; _found=0
    if [[ ${#ALL_ACCOUNTS[@]} -gt 0 ]]; then
        for _acct in "${ALL_ACCOUNTS[@]}"; do
            while IFS= read -r _entry; do
                [[ -z "$_entry" ]] && continue
                if [[ "$_entry" == *"|"* ]]; then
                    _dname="${_entry%%|*}"; _dpath="${_entry##*|}"
                    if [[ -d "$_dpath" ]]; then inspect_domain "$_dname" "$_dpath"; _found=$((_found + 1)); fi
                else
                    _dr=$(resolve_docroot "$_entry"); if [[ -n "$_dr" && -d "$_dr" ]]; then inspect_domain "$_entry" "$_dr"; _found=$((_found + 1)); fi
                fi
            done < <(discover_account_domains "$_acct")
            [[ $_found -ge 50 ]] && echo "truncated_at_50_domains" && break
        done
    fi
    echo "domains_found=$_found"
fi
fi

