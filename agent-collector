# ---------------------------------------------------------------------------
# 7. In-memory malware detection
# ---------------------------------------------------------------------------
if _run_section "inmemory"; then
echo "===SECTION:inmemory_malware==="

# 7a. Processes running from deleted binaries
echo "---deleted_binaries---"
for pid_dir in /proc/[0-9]*; do
    pid="${pid_dir##*/}"
    exe_link=$(readlink "${pid_dir}/exe" 2>/dev/null || echo "")
    if [[ "$exe_link" == *"(deleted)"* ]]; then
        cmd=$(tr '\0' ' ' < "${pid_dir}/cmdline" 2>/dev/null | head -c 200 || echo "")
        owner_uid=$(awk '/^Uid:/{print $2}' "${pid_dir}/status" 2>/dev/null || echo "?")
        owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
        echo "pid=${pid}|exe=${exe_link}|user=${owner_name}|cmd=${cmd}"
    fi
done 2>/dev/null

# 7b. Files in /dev/shm (shared memory payloads)
echo "---dev_shm---"
ls -la /dev/shm/ 2>/dev/null | grep -v '^total' | grep -v '^d' | head -30 || echo "empty"

# 7c. Processes using memfd (fileless execution)
echo "---memfd_processes---"
for pid_dir in /proc/[0-9]*; do
    pid="${pid_dir##*/}"
    # Check fd links for memfd references
    found_memfd=""
    for fd in "${pid_dir}/fd"/*; do
        target=$(readlink "$fd" 2>/dev/null || echo "")
        if [[ "$target" == *"/memfd:"* || "$target" == *"memfd:"* ]]; then
            found_memfd="${found_memfd}${target}; "
        fi
    done 2>/dev/null
    if [[ -n "$found_memfd" ]]; then
        cmd=$(tr '\0' ' ' < "${pid_dir}/cmdline" 2>/dev/null | head -c 200 || echo "")
        owner_uid=$(awk '/^Uid:/{print $2}' "${pid_dir}/status" 2>/dev/null || echo "?")
        owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
        echo "pid=${pid}|user=${owner_name}|memfd=${found_memfd}|cmd=${cmd}"
    fi
done 2>/dev/null

# 7d. Suspicious /tmp executables (random-named binaries/scripts)
echo "---tmp_executables---"
find /tmp -maxdepth 2 -type f \( -perm -u+x -o -name '*.sh' -o -name '*.pl' -o -name '*.py' \) \
    -printf '%T@ %u %s %m %p\n' 2>/dev/null | sort -rn | head -20 | \
    $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
# Also check for recently created files with random-looking names
find /tmp -maxdepth 2 -type f -mtime -7 -regex '.*/[a-zA-Z0-9]\{6,\}$' \
    -printf '%T@ %u %s %m %p\n' 2>/dev/null | sort -rn | head -20 | \
    $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'

# 7e. High-CPU processes (top 10 by CPU, non-root)
echo "---high_cpu_processes---"
ps -eo pid,user,%cpu,%mem,etime,args --sort=-%cpu 2>/dev/null | \
    awk 'NR==1 || ($3+0 > 5.0 && $2 != "root" && $2 != "mysql" && $2 != "named")' | head -15 || echo "none"

# 7f. Open file descriptors of high-CPU processes (maps/fds for top suspicious PIDs)
echo "---hicpu_fd_details---"
if [[ -n "$OWNER" ]]; then
    OWNER_UID=$(id -u "$OWNER" 2>/dev/null || echo "")
fi
for pid in $(ps -eo pid,%cpu,user --sort=-%cpu 2>/dev/null | awk -v ou="${OWNER_UID:-}" \
    'NR>1 && $2+0 > 10.0 { if (ou == "" || $3 != "root") print $1 }' | head -5); do
    echo "---pid:${pid}---"
    exe=$(readlink "/proc/${pid}/exe" 2>/dev/null || echo "unknown")
    cmd=$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null | head -c 300 || echo "unknown")
    owner_uid=$(awk '/^Uid:/{print $2}' "/proc/${pid}/status" 2>/dev/null || echo "?")
    owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
    echo "exe=${exe}"
    echo "cmd=${cmd}"
    echo "user=${owner_name}"
    # Memory maps — look for suspicious mapped files
    grep -vE 'lib(c|pthread|dl|m|rt|nss|resolv|crypt|z\.|ssl|crypto|pcre|xml|curl|gmp|icu)' \
        "/proc/${pid}/maps" 2>/dev/null | grep -v '\[' | awk '{print $NF}' | sort -u | head -20 || echo "maps=unavailable"
    # Open FDs
    ls -la "/proc/${pid}/fd" 2>/dev/null | grep -v '/dev/null\|/dev/pts\|pipe:\|socket:\|anon_inode' | head -20 || echo "fds=unavailable"
done 2>/dev/null
fi # end inmemory

