#!/bin/bash
# ============================================================================
# im360_remediation_collector.sh
#
# Remote forensic data collector for Imunify360 incident investigation.
# All commands are strictly read-only.
#
# Usage:
#   bash im360_remediation_collector.sh [OPTIONS]
#
# Options:
#   --owner OWNER     System/panel account to investigate
#   --domain DOMAIN   Single domain to investigate
#   --domains LIST    Comma-separated domains to filter logs & build JSON summary
#   --out FILE        Write output to FILE instead of stdout (for manual runs)
#   --sections LIST   Only run listed sections (comma-separated)
#   --no-dry-run      Run full collection (default is dry-run: connect + "w" only)
#   --dry-run         Connectivity check only
#   --help            Show usage
#
# Output: delimited sections that the Python backend parses into JSON.
# Each section starts with ===SECTION:<name>=== and ends at the next section
# or EOF. Field values are one-per-line or structured key=value pairs.
#
# Section groups:
#   system       - Basic system info (hostname, kernel, uptime)
#   imunify      - Imunify360 agent info and features
#   user_info    - Account info, crontabs, recent PHP, suspicious files
#   filesystem   - Hidden files, recent PHP, uploads PHP, strange PHP,
#                  permissions, root files, cagefs PHP, malware sigs, htaccess
#   domain_info  - Document root, WordPress details, WP users
#   imunify_db   - Local SQLite DB queries (resident + main DB)
#   network      - Active connections, suspicious processes
#   inmemory     - In-memory malware detection (deleted bins, memfd, /tmp, hi-CPU)
#   malware_log  - Imunify console.log malware extraction
#   logs         - Tail of all relevant log files
# ============================================================================

# NOTE: -e is intentionally omitted. This collector must run to completion and
# emit every section even when individual commands fail (missing tools, perm
# errors, SIGPIPE from head truncation). Each command already handles failure
# via 2>/dev/null and || fallbacks.
set -uo pipefail

OWNER=""
DOMAIN=""
TARGET_DOMAINS=""
OUTFILE=""
DRY_RUN="false"
SECTIONS=""
HOMEDIR=""

# Detect awk variant — strftime() requires gawk. If unavailable, timestamps
# in find output will appear as raw epoch numbers (still parseable).
if command -v gawk &>/dev/null; then
    _AWK=gawk
elif awk 'BEGIN{exit (strftime("%Y",0)=="1970"?0:1)}' 2>/dev/null; then
    _AWK=awk
else
    _AWK=awk   # strftime calls will print empty strings; harmless
    echo "WARNING: gawk not found — timestamps will be raw epoch values" >&2
fi

# ============================================================================
# Helper functions
# ============================================================================

show_help() {
    echo "Usage: bash $(basename "$0") [OPTIONS]"
    echo ""
    echo "  --owner <USER>        Target a specific hosting account."
    echo "  --domain <DOMAIN>     Single domain to investigate."
    echo "  --domains <LIST>      Comma-separated domains to filter logs & JSON summary."
    echo "  --out <FILE>          Save output to file."
    echo "  --sections <LIST>     Only run listed sections (comma-separated)."
    echo "  --no-dry-run          Execute full scan (required for collection)."
    echo "  --dry-run             Connectivity check only (default)."
    echo "  --help                Show this help."
    exit 0
}

_run_section() {
    [[ -z "$SECTIONS" ]] && return 0
    local section="$1"
    local IFS=','
    for s in $SECTIONS; do
        [[ "$s" == "$section" ]] && return 0
    done
    return 1
}

# NEW: CMS detection (WordPress, Joomla, PrestaShop, Magento, Laravel, OpenCart)
detect_cms() {
    local dir="$1"
    [[ ! -d "$dir" ]] && echo "Invalid Path" && return
    if [[ -f "$dir/wp-config.php" ]]; then
        local ver="Unknown"
        [[ -f "$dir/wp-includes/version.php" ]] && ver=$(grep "wp_version =" "$dir/wp-includes/version.php" 2>/dev/null | cut -d"'" -f2)
        echo "WordPress (v${ver:-Unknown})"; return
    fi
    [[ -f "$dir/configuration.php" && -d "$dir/administrator" ]] && echo "Joomla" && return
    [[ -f "$dir/config/settings.inc.php" ]] && echo "PrestaShop" && return
    [[ -f "$dir/app/etc/env.php" ]] && echo "Magento" && return
    [[ -f "$dir/artisan" ]] && echo "Laravel" && return
    [[ -f "$dir/config.php" && -d "$dir/admin" ]] && echo "OpenCart" && return
    echo "Unknown/Custom"
}

# NEW: Nested app discovery for JSON summary
scan_nested_apps_json() {
    local root="$1"
    local json_items=""
    while IFS= read -r -d '' file; do
        local app_dir=$(dirname "$file")
        [[ "$app_dir" == "$root" || "$app_dir/" == "$root/" ]] && continue
        local child_type=$(detect_cms "$app_dir")
        local rel_path="${app_dir#$root}"
        if [[ "$child_type" != "Unknown/Custom" ]]; then
            [[ -n "$json_items" ]] && json_items="$json_items, "
            json_items="$json_items{ \"app\": \"$child_type\", \"path\": \"$rel_path\" }"
        fi
    done < <(find "$root" -maxdepth 5 \( -name "wp-config.php" -o -name "configuration.php" -o -name "artisan" -o -name "config.php" \) ! -path "*/vendor/*" ! -path "*/cache/*" ! -path "*/wp-includes/*" -print0 2>/dev/null)
    echo "$json_items"
}

# NEW: Resolve docroot with broader panel support (Plesk, DA, cPanel, Nginx)
resolve_docroot_extended() {
    local _dom="$1"
    # Plesk
    [[ -d "/var/www/vhosts/$_dom/httpdocs" ]] && echo "/var/www/vhosts/$_dom/httpdocs" && return
    [[ -d "/var/www/vhosts/$_dom" ]] && echo "/var/www/vhosts/$_dom" && return
    # DirectAdmin
    local da_path=$(find /home -maxdepth 4 -path "*/domains/$_dom/public_html" -type d 2>/dev/null | head -1)
    [[ -n "$da_path" ]] && echo "$da_path" && return
    # cPanel
    if [[ -f /etc/userdomains ]]; then
        local user=$(grep "^${_dom}:" /etc/userdomains 2>/dev/null | cut -d: -f2 | xargs)
        if [[ -n "$user" && -d "/home/$user/public_html" ]]; then echo "/home/$user/public_html"; return; fi
    fi
    # Generic
    [[ -d "/var/www/$_dom/public_html" ]] && echo "/var/www/$_dom/public_html" && return
    # Apache/Nginx config grep
    for conf in /etc/apache2/sites-enabled /etc/httpd/conf.d /usr/local/apache/conf/httpd.conf /etc/httpd/conf/httpd.conf /etc/nginx/sites-enabled; do
        local _dr=""
        if [[ -d "$conf" ]]; then
            _dr=$(grep -rli "$_dom" "$conf" 2>/dev/null | head -1 | xargs grep -iE 'DocumentRoot|root' 2>/dev/null | head -1 | awk '{print $2}' | tr -d '";')
        elif [[ -f "$conf" ]]; then
            _dr=$(grep -A10 "$_dom" "$conf" 2>/dev/null | grep -iE 'DocumentRoot|root' | head -1 | awk '{print $2}' | tr -d '";')
        fi
        [[ -n "${_dr:-}" && -d "${_dr:-}" ]] && echo "$_dr" && return
    done
    # Owner fallback
    if [[ -n "$OWNER" ]]; then
        for base in /home /home2 /var/www /var/vhosts; do
            [[ -d "${base}/${OWNER}/public_html" ]] && echo "${base}/${OWNER}/public_html" && return
            [[ -d "${base}/${OWNER}/${_dom}" ]] && echo "${base}/${OWNER}/${_dom}" && return
        done
    fi
    echo "NOT_FOUND"
}

# ============================================================================
# Argument parsing
# ============================================================================

while [[ $# -gt 0 ]]; do
    case "$1" in
        --owner)      [[ $# -ge 2 ]] && OWNER="$2" && shift 2 || { echo "ERROR: --owner requires a value" >&2; shift; } ;;
        --domain)     [[ $# -ge 2 ]] && DOMAIN="$2" && shift 2 || { echo "ERROR: --domain requires a value" >&2; shift; } ;;
        --domains)    [[ $# -ge 2 ]] && TARGET_DOMAINS="$2" && shift 2 || { echo "ERROR: --domains requires a value" >&2; shift; } ;;
        --out)        [[ $# -ge 2 ]] && OUTFILE="$2" && shift 2 || { echo "ERROR: --out requires a value" >&2; shift; } ;;
        --sections)   [[ $# -ge 2 ]] && SECTIONS="$2" && shift 2 || { echo "ERROR: --sections requires a value" >&2; shift; } ;;
        --no-dry-run) DRY_RUN="false"; shift ;;
        --dry-run)    DRY_RUN="true"; shift ;;
        --help|-h)    show_help ;;
        *)            shift ;;
    esac
done

# NEW: Merge --domain into TARGET_DOMAINS for JSON summary / log filtering
if [[ -n "$DOMAIN" && -n "$TARGET_DOMAINS" ]]; then
    TARGET_DOMAINS="$TARGET_DOMAINS,$DOMAIN"
elif [[ -n "$DOMAIN" && -z "$TARGET_DOMAINS" ]]; then
    TARGET_DOMAINS="$DOMAIN"
fi

# If --out is set, redirect all subsequent stdout to that file
if [[ -n "$OUTFILE" ]]; then
    exec > "$OUTFILE"
    echo "Writing output to $OUTFILE" >&2
fi

# ---------------------------------------------------------------------------
# Dry-run mode (default): verify connectivity by running "w" and exit.
# Pass --no-dry-run to execute the full forensic collection.
# ---------------------------------------------------------------------------
if [[ "$DRY_RUN" == "true" ]]; then
    echo "===SECTION:dry_run==="
    echo "mode=dry_run"
    echo "hostname=$(hostname 2>/dev/null || echo unknown)"
    echo "current_time=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null || echo unknown)"
    echo "---w---"
    w 2>/dev/null || echo "w_unavailable"
    echo "===SECTION:done==="
    echo "collector_finished=dry_run"
    echo "timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null)"
    exit 0
fi

# ============================================================================
# FULL FORENSIC COLLECTION
# ============================================================================

# ---------------------------------------------------------------------------
# 1. System Information (always runs — lightweight)
# ---------------------------------------------------------------------------
echo "===SECTION:system==="
echo "hostname=$(hostname 2>/dev/null || echo unknown)"
echo "kernel=$(uname -r 2>/dev/null || echo unknown)"
echo "arch=$(uname -m 2>/dev/null || echo unknown)"
echo "os=$(cat /etc/redhat-release 2>/dev/null || grep -m1 '^PRETTY_NAME=' /etc/os-release 2>/dev/null | cut -d= -f2- | tr -d '"' || echo unknown)"
echo "uptime=$(uptime -p 2>/dev/null || uptime 2>/dev/null || echo unknown)"
echo "load=$(cat /proc/loadavg 2>/dev/null || echo unknown)"
echo "current_time=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null || echo unknown)"

# ---------------------------------------------------------------------------
# 2. Imunify360 Agent
# ---------------------------------------------------------------------------
if _run_section "imunify"; then
echo "===SECTION:imunify==="
if command -v imunify360-agent &>/dev/null; then
    echo "installed=yes"
    imunify360-agent version 2>/dev/null || echo "version=unknown"
    echo "---features---"
    imunify360-agent features list 2>/dev/null || echo "features=unavailable"
    echo "---config---"
    imunify360-agent config show 2>/dev/null | head -80 || echo "config=unavailable"
    echo "---signature_db---"
    cat /var/imunify360/files/sigs/v1/description.json 2>/dev/null || echo "not_found"
    echo "---default_action---"
    imunify360-agent config show -v --json 2>/dev/null | grep default_action || echo "unavailable"
    echo "---sends_file_for_analysis---"
    imunify360-agent config show -v --json 2>/dev/null | grep sends_file_for_analysis || echo "unavailable"
    echo "---proactive_defense---"
    grep PROACTIVE -A5 /etc/sysconfig/imunify360/imunify360-merged.config 2>/dev/null || echo "unavailable"
    echo "---install_date---"
    head -20 /var/log/i360deploy.log 2>/dev/null || echo "not_found"
else
    echo "installed=no"
fi
fi # end imunify

# ---------------------------------------------------------------------------
# 2b. Discover all hosting accounts (non-system users)
#     Outputs: user, uid, home, docroot for every real hosting account.
#     Always runs so later sections can reference ALL_ACCOUNTS[].
# ---------------------------------------------------------------------------
echo "===SECTION:accounts==="

# Known system / service account names to skip
# Exact-match system account names
_SYS_EXACT='root|bin|daemon|adm|lp|sync|shutdown|halt|mail|operator|games|ftp|nobody|dbus|polkitd|sshd|postfix|chrony|ntp|nscd|tcpdump|avahi|mysql|mysqld|postgres|redis|memcached|mongodb|nginx|apache|httpd|www-data|lighttpd|named|dovecot|cyrus|exim|mailman|mailnull|smmsp|clamav|clamupdate|amavis|opendkim|whm|softaculous|solr|tomcat|prosody|varnish|haproxy|plesk|psa|drweb|imunify360|imav-hoster|roundcube|psaadm|psaftp|git|svn|puppet|chef|docker|libvirt|qemu|virtuser|lsadm|litespeed|lscpd|nfsnobody|rpc|rpcuser|saslauth|abrt|setroubleshoot|sssd|gdm|unbound|gluster|ovirt|zabbix|nagios|prometheus|grafana|node_exporter|elasticsearch|kibana|logstash|jenkins|gitlab|deployer|ansible|ec2-user|centos|ubuntu|cloud-user|oprofile'
# Prefix-match patterns (systemd-*, cpanel*, ossec*, _imunify*, sw-cp-*, gnome-*)
_SYS_PREFIX='systemd-|cpanel|ossec|_imunify|imunify360-|sw-cp-|sw-engine|gnome-initial'

declare -a ALL_ACCOUNTS=()
_acct_count=0

# Gather accounts from getent (UID >= 500, excluding system names)
while IFS=: read -r _uname _ _uid _ _ _uhome _; do
    [[ -z "$_uname" ]] && continue
    # Skip low UIDs (system accounts) — UID 500+ on RHEL/CentOS, 1000+ on Debian
    [[ "$_uid" -lt 500 ]] 2>/dev/null && continue
    # Skip known service accounts by name (exact or prefix match)
    echo "$_uname" | grep -qE "^(${_SYS_EXACT})$" && continue
    echo "$_uname" | grep -qE "^(${_SYS_PREFIX})" && continue
    # Must have a real home directory
    [[ -z "$_uhome" || "$_uhome" == "/" || "$_uhome" == "/bin"* || "$_uhome" == "/sbin"* || "$_uhome" == "/usr"* || "$_uhome" == "/dev"* ]] && continue

    # Find document root
    _docroot=""
    for _dr_cand in \
        "${_uhome}/public_html" \
        "${_uhome}/httpdocs" \
        "${_uhome}/htdocs" \
        "${_uhome}/www" \
        "${_uhome}/web" \
        "${_uhome}/public"; do
        if [[ -d "$_dr_cand" ]]; then
            _docroot="$_dr_cand"
            break
        fi
    done

    # Plesk: /var/www/vhosts/<domain>/httpdocs owned by this user
    if [[ -z "$_docroot" && -d "/var/www/vhosts" ]]; then
        for _vd in /var/www/vhosts/*/httpdocs; do
            [[ -d "$_vd" ]] || continue
            if [[ "$(stat -c '%U' "$_vd" 2>/dev/null)" == "$_uname" ]]; then
                _docroot="$_vd"
                break
            fi
        done
    fi

    # Check WordPress
    _wp="no"
    if [[ -n "$_docroot" && -f "${_docroot}/wp-config.php" ]]; then
        _wp="yes"
    fi

    echo "account=${_uname}|uid=${_uid}|home=${_uhome}|docroot=${_docroot:-none}|wordpress=${_wp}|home_exists=$([[ -d "$_uhome" ]] && echo yes || echo no)"
    ALL_ACCOUNTS+=("$_uname")
    _acct_count=$((_acct_count + 1))
done < <(getent passwd 2>/dev/null)

# Also check cPanel user list (catches accounts even if passwd entry is odd)
if [[ -d /var/cpanel/users ]]; then
    for _cpf in /var/cpanel/users/*; do
        [[ -f "$_cpf" ]] || continue
        _cpuser=$(basename "$_cpf")
        # Skip if already listed
        printf '%s\n' "${ALL_ACCOUNTS[@]}" 2>/dev/null | grep -qx "$_cpuser" && continue
        _cphome=""
        for _base in /home /home2; do
            [[ -d "${_base}/${_cpuser}" ]] && _cphome="${_base}/${_cpuser}" && break
        done
        [[ -z "$_cphome" ]] && continue
        _docroot=""
        [[ -d "${_cphome}/public_html" ]] && _docroot="${_cphome}/public_html"
        _wp="no"
        [[ -n "$_docroot" && -f "${_docroot}/wp-config.php" ]] && _wp="yes"
        echo "account=${_cpuser}|uid=cpanel|home=${_cphome}|docroot=${_docroot:-none}|wordpress=${_wp}|home_exists=yes"
        ALL_ACCOUNTS+=("$_cpuser")
        _acct_count=$((_acct_count + 1))
    done
fi

# DirectAdmin user list
if [[ -d /usr/local/directadmin/data/users ]]; then
    for _daf in /usr/local/directadmin/data/users/*/; do
        [[ -d "$_daf" ]] || continue
        _dauser=$(basename "$_daf")
        printf '%s\n' "${ALL_ACCOUNTS[@]}" 2>/dev/null | grep -qx "$_dauser" && continue
        _dahome=""
        for _base in /home /home2; do
            [[ -d "${_base}/${_dauser}" ]] && _dahome="${_base}/${_dauser}" && break
        done
        [[ -z "$_dahome" ]] && continue
        _docroot=""
        for _dr_cand in "${_dahome}/public_html" "${_dahome}/domains"; do
            [[ -d "$_dr_cand" ]] && _docroot="$_dr_cand" && break
        done
        _wp="no"
        [[ -n "$_docroot" && -f "${_docroot}/wp-config.php" ]] && _wp="yes"
        echo "account=${_dauser}|uid=da|home=${_dahome}|docroot=${_docroot:-none}|wordpress=${_wp}|home_exists=yes"
        ALL_ACCOUNTS+=("$_dauser")
        _acct_count=$((_acct_count + 1))
    done
fi

echo "total_accounts=${_acct_count}"

# ---------------------------------------------------------------------------
# 2c. WordPress Sites Discovery
#     Finds ALL wp-config.php across account home directories.
#     For each site: account owner, site path, WP version.
# ---------------------------------------------------------------------------
echo "===SECTION:wordpress_sites==="
_wp_count=0

_discover_wp_sites() {
    local _acctname="$1"
    local _searchdir="$2"
    [[ -d "$_searchdir" ]] || return
    while IFS= read -r _wpcfg; do
        [[ -z "$_wpcfg" ]] && continue
        local _wpdir
        _wpdir=$(dirname "$_wpcfg")
        # Extract version from wp-includes/version.php
        local _ver="unknown"
        if [[ -f "${_wpdir}/wp-includes/version.php" ]]; then
            _ver=$(grep -oP "\\\$wp_version\s*=\s*'[^']+'" "${_wpdir}/wp-includes/version.php" 2>/dev/null | grep -oP "'[^']+'" | tr -d "'" || echo "unknown")
            [[ -z "$_ver" ]] && _ver="unknown"
        fi
        # Check if site appears active (has wp-settings.php)
        local _active="yes"
        [[ ! -f "${_wpdir}/wp-settings.php" ]] && _active="partial"
        # DB prefix
        local _dbpfx
        _dbpfx=$(grep -m1 'table_prefix' "$_wpcfg" 2>/dev/null | grep -oP "'[^']+'" | head -1 | tr -d "'" || echo "wp_")
        [[ -z "$_dbpfx" ]] && _dbpfx="wp_"
        echo "wp_site=${_acctname}|path=${_wpdir}|version=${_ver}|db_prefix=${_dbpfx}|active=${_active}"
        _wp_count=$((_wp_count + 1))
    done < <(find "$_searchdir" -maxdepth 5 -name 'wp-config.php' -type f 2>/dev/null)
}

if [[ -n "$OWNER" ]]; then
    # Single owner: search their home
    _ownerhome=""
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        _ownerhome="$HOMEDIR"
    else
        for _base in /home /home2 /var/www /var/vhosts; do
            [[ -d "${_base}/${OWNER}" ]] && _ownerhome="${_base}/${OWNER}" && break
        done
    fi
    if [[ -n "$_ownerhome" ]]; then
        _discover_wp_sites "$OWNER" "$_ownerhome"
    fi
elif [[ ${#ALL_ACCOUNTS[@]} -gt 0 ]]; then
    # All accounts: resolve each home and scan
    while IFS=: read -r _uname _ _ _ _ _uhome _; do
        [[ -z "$_uname" || -z "$_uhome" ]] && continue
        printf '%s\n' "${ALL_ACCOUNTS[@]}" 2>/dev/null | grep -qx "$_uname" || continue
        _discover_wp_sites "$_uname" "$_uhome"
        [[ $_wp_count -ge 200 ]] && echo "truncated_at_200" && break
    done < <(getent passwd 2>/dev/null)
fi

echo "total_wp_sites=${_wp_count}"

# ---------------------------------------------------------------------------
# 3. User / Account Info
# ---------------------------------------------------------------------------
if _run_section "user_info"; then
echo "===SECTION:user_info==="
if [[ -n "$OWNER" ]]; then
    echo "owner=$OWNER"
    # Try common home paths
    HOMEDIR=""
    for base in /home /home2 /var/www /var/vhosts; do
        if [[ -d "${base}/${OWNER}" ]]; then
            HOMEDIR="${base}/${OWNER}"
            break
        fi
    done
    if [[ -z "$HOMEDIR" ]]; then
        # Fallback: extract only the home-directory field (field 6) from getent
        # No raw passwd content is stored — just the path string
        HOMEDIR=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
        HOMEDIR="${HOMEDIR:-}"
    fi
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        echo "home=$HOMEDIR"
        echo "disk_usage=$(du -sh "$HOMEDIR" 2>/dev/null | awk '{print $1}' || echo unknown)"
        echo "---home_listing---"
        ls -la "$HOMEDIR" 2>/dev/null | head -50
    else
        echo "home=not_found"
    fi

    # Crontab
    echo "---crontab---"
    crontab -l -u "$OWNER" 2>/dev/null || echo "no_crontab"

    # Recently modified PHP files (last 7 days)
    echo "---recent_php_files---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        find "$HOMEDIR" -name '*.php' -mtime -7 -type f \
            ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' \
            -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -60 | \
            $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    else
        echo "skipped_no_homedir"
    fi

    # Suspicious files: PHP in uploads, hidden directories
    echo "---suspicious_files---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        # PHP files in upload dirs
        find "$HOMEDIR" -type f -name '*.php' \( -path '*/uploads/*' -o -path '*/upload/*' -o -path '*/tmp/*' \) \
            -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -30 | \
            $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
        # Files in hidden directories (dot-dirs)
        find "$HOMEDIR" -maxdepth 4 -type f -path '*/.*/*' \
            ! -path '*/.git/*' ! -path '*/.npm/*' \
            ! -path '*/.cache/*' ! -path '*/.cpanel/*' ! -path '*/.local/*' \
            ! -path '*/.config/*' ! -path '*/.composer/*' ! -path '*/.wp-cli/*' \
            -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -30 | \
            $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    else
        echo "skipped_no_homedir"
    fi

    # World-writable files
    echo "---world_writable---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        find "$HOMEDIR" -maxdepth 5 -type f -perm -o+w \
            ! -path '*/cache/*' ! -path '*/tmp/*' ! -path '*/logs/*' \
            -printf '%m %s %p\n' 2>/dev/null | head -30
    else
        echo "skipped_no_homedir"
    fi
else
    echo "owner=not_specified"
fi
fi # end user_info

# ---------------------------------------------------------------------------
# Resolve HOMEDIR if not already set (user_info section may have been skipped)
# ---------------------------------------------------------------------------
if [[ -n "$OWNER" && -z "$HOMEDIR" ]]; then
    for _base in /home /home2 /var/www /var/vhosts; do
        if [[ -d "${_base}/${OWNER}" ]]; then
            HOMEDIR="${_base}/${OWNER}"
            break
        fi
    done
    if [[ -z "$HOMEDIR" ]]; then
        HOMEDIR=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
        HOMEDIR="${HOMEDIR:-}"
    fi
fi

# ---------------------------------------------------------------------------
# Build list of base paths to scan + owner filter (reused by many sections)
# This runs unconditionally so variables are available to all gated sections.
# ---------------------------------------------------------------------------
SCAN_DIRS=()
OWNER_FILTER=()
if [[ -n "$OWNER" ]]; then
    OWNER_FILTER=(-user "$OWNER")
    # Owner-scoped: use their home directory
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        SCAN_DIRS=("$HOMEDIR")
    else
        # Try getent to resolve home
        _hdir=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
        if [[ -n "$_hdir" && -d "$_hdir" ]]; then
            SCAN_DIRS=("$_hdir")
        fi
    fi
else
    # No owner: scan all user base paths that exist
    for _base in /home /home2 /var/www /var/vhosts; do
        [[ -d "$_base" ]] && SCAN_DIRS+=("$_base")
    done
fi

# ---------------------------------------------------------------------------
# Hidden files scan (user space only, skips known safe dot-dirs)
# ---------------------------------------------------------------------------
if _run_section "filesystem"; then
echo "===SECTION:hidden_files==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    echo "---hidden_files_recent---"
    # Hidden files (dot-name) modified in last 30 days, skip safe dirs
    find "${SCAN_DIRS[@]}" -maxdepth 6 -type f -name '.*' -mtime -30 \
        ! -path '*/.git/*' ! -path '*/.npm/*' \
        ! -path '*/.cache/*' ! -path '*/.cpanel/*' ! -path '*/.local/*' \
        ! -path '*/.config/*' ! -path '*/.composer/*' ! -path '*/.wp-cli/*' \
        ! -path '*/.ssh/*' ! -path '*/.gnupg/*' ! -path '*/.pki/*' \
        ! -path '*/.nvm/*' ! -path '*/.yarn/*' ! -path '*/.rvm/*' \
        ! -path '*/.cagefs/*' ! -path '*/.cl.selector/*' ! -path '*/.passenger/*' \
        ! -path '*/.softaculous/*' ! -path '*/.trash/*' ! -path '*/.Trash/*' \
        ! -path '*/.rapid-scan-db/*' ! -path '*/.skel/*' ! -path '*/.wp-toolkit/*' \
        ! -path '*/.webstat/*' \
        ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
        ! -name '.bashrc' ! -name '.bash_profile' ! -name '.bash_history' \
        ! -name '.bash_logout' ! -name '.profile' ! -name '.htaccess' \
        ! -name '.gitignore' ! -name '.DS_Store' ! -name '.env' \
        ! -name '.imunify_patch_id' ! -name '.myimunify_id' \
        ! -name '.php-version' ! -name '.php-ini' \
        -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
        $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'

    echo "---files_inside_hidden_dirs---"
    # Files inside hidden directories (common malware hiding spot)
    find "${SCAN_DIRS[@]}" -maxdepth 6 -type f -path '*/.*/*' \
        ! -path '*/.git/*' ! -path '*/.npm/*' \
        ! -path '*/.cache/*' ! -path '*/.cpanel/*' ! -path '*/.local/*' \
        ! -path '*/.config/*' ! -path '*/.composer/*' ! -path '*/.wp-cli/*' \
        ! -path '*/.ssh/*' ! -path '*/.gnupg/*' ! -path '*/.pki/*' \
        ! -path '*/.nvm/*' ! -path '*/.yarn/*' ! -path '*/.rvm/*' \
        ! -path '*/.cagefs/*' ! -path '*/.cl.selector/*' ! -path '*/.passenger/*' \
        ! -path '*/.softaculous/*' ! -path '*/.trash/*' ! -path '*/.Trash/*' \
        ! -path '*/.gem/*' ! -path '*/.bundle/*' \
        ! -path '*/.rapid-scan-db/*' ! -path '*/.skel/*' ! -path '*/.wp-toolkit/*' \
        ! -path '*/.webstat/*' \
        ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
        -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
        $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# Recently modified PHP files (user space, last 7 days)
# ---------------------------------------------------------------------------
echo "===SECTION:recent_php==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    if [[ -n "$OWNER" ]]; then
        # Owner-scoped: only files owned by that user
        find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' -mtime -7 \
            -user "$OWNER" \
            ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -300 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    else
        find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' -mtime -7 \
            ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -300 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    fi
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# PHP files in wp-content/uploads (should never contain PHP)
# ---------------------------------------------------------------------------
echo "===SECTION:php_in_uploads==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    if [[ -n "$OWNER" ]]; then
        find "${SCAN_DIRS[@]}" -maxdepth 10 -type f -name '*.php*' \
            -path '*/wp-content/uploads/*' -user "$OWNER" \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    else
        find "${SCAN_DIRS[@]}" -maxdepth 10 -type f -name '*.php*' \
            -path '*/wp-content/uploads/*' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    fi
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# Strange PHP files (random/hex names typical of malware droppers)
# ---------------------------------------------------------------------------
echo "===SECTION:strange_php==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    if [[ -n "$OWNER" ]]; then
        find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -user "$OWNER" \( \
            -regex '.*/[a-z0-9]\{32\}\.php' \
            -o -regex '.*/[a-f0-9]\{8,16\}\.php' \
            -o -regex '.*/\.[a-z0-9]\{6,\}\.php' \
            -o -regex '.*/[0-9]\{5,\}\.php' \
            \) \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    else
        find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \( \
            -regex '.*/[a-z0-9]\{32\}\.php' \
            -o -regex '.*/[a-f0-9]\{8,16\}\.php' \
            -o -regex '.*/\.[a-z0-9]\{6,\}\.php' \
            -o -regex '.*/[0-9]\{5,\}\.php' \
            \) \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    fi
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# World-writable files and folders + files not owned by expected user
# ---------------------------------------------------------------------------
echo "===SECTION:permissions==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    echo "---world_writable---"
    if [[ -n "$OWNER" ]]; then
        find "${SCAN_DIRS[@]}" -maxdepth 8 -user "$OWNER" -perm -o+w \
            ! -path '*/cache/*' ! -path '*/tmp/*' ! -path '*/logs/*' \
            ! -path '*/reports/*.log' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%m %T@ %u %s %p\n' 2>/dev/null | sort -k2 -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", $1, strftime("%Y-%m-%d %H:%M:%S", $2), $3, $4, $5}'
    else
        find "${SCAN_DIRS[@]}" -maxdepth 8 -perm -o+w \
            ! -path '*/cache/*' ! -path '*/tmp/*' ! -path '*/logs/*' \
            ! -path '*/reports/*.log' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            -printf '%m %T@ %u %s %p\n' 2>/dev/null | sort -k2 -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", $1, strftime("%Y-%m-%d %H:%M:%S", $2), $3, $4, $5}'
    fi

    echo "---not_owned_by_user---"
    if [[ -n "$OWNER" ]]; then
        # Files inside owner's home NOT owned by them (suspicious ownership change)
        find "${SCAN_DIRS[@]}" -maxdepth 8 ! -user "$OWNER" \
            ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' \
            ! -path '*/reports/*.log' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            ! -user root ! -user nobody \
            -printf '%m %T@ %u %s %p\n' 2>/dev/null | sort -k2 -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", $1, strftime("%Y-%m-%d %H:%M:%S", $2), $3, $4, $5}'
    else
        echo "skipped_no_owner"
    fi
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# Root-owned files in user space (potential privilege escalation / rootkit)
# ---------------------------------------------------------------------------
echo "===SECTION:root_files==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    if [[ -n "$OWNER" && -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        # Root-owned files inside this user's home — shouldn't normally exist
        find "$HOMEDIR" -maxdepth 8 -user root -type f \
            ! -path '*/.cagefs/*' ! -path '*/.cl.selector/*' \
            ! -path '*/.cpanel/*' ! -path '*/.passenger/*' \
            ! -path '*/chroot/*' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            ! -path '*/logs/access*' ! -path '*/logs/proxy*' \
            ! -name 'access_ssl_log' ! -path '*/.webstat/*' \
            ! -name '.bashrc' ! -name '.bash_profile' ! -name '.bash_logout' \
            -printf '%T@ %s %m %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4}'
    else
        # No owner: scan all user bases for root-owned files
        find "${SCAN_DIRS[@]}" -maxdepth 6 -user root -type f \
            ! -path '*/.cagefs/*' ! -path '*/.cl.selector/*' \
            ! -path '*/.cpanel/*' ! -path '*/.passenger/*' \
            ! -path '*/chroot/*' \
            ! -path '*/vhosts/system/*' ! -path '*/error_docs/*' \
            ! -path '*/.rapid-scan-db/*' \
            ! -path '*/logs/access*' ! -path '*/logs/proxy*' \
            ! -name 'access_ssl_log' ! -path '*/.webstat/*' \
            ! -name '.bashrc' ! -name '.bash_profile' ! -name '.bash_logout' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    fi
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# PHP files inside .cagefs (should not contain user PHP files)
# ---------------------------------------------------------------------------
echo "===SECTION:php_in_cagefs==="
if [[ -n "$OWNER" && -n "$HOMEDIR" && -d "${HOMEDIR}/.cagefs" ]]; then
    find "${HOMEDIR}/.cagefs" -maxdepth 8 -type f -name '*.php*' \
        -printf '%T@ %s %m %p\n' 2>/dev/null | sort -rn | head -200 | \
        $_AWK '{printf "%s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4}'
elif [[ -z "$OWNER" ]]; then
    for _base in /home /home2; do
        [[ -d "$_base" ]] || continue
        find "$_base" -maxdepth 6 -type f -name '*.php*' -path '*/.cagefs/*' \
            -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -200 | \
            $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    done
else
    echo "no_cagefs_dir"
fi

# ---------------------------------------------------------------------------
# Malware signature scanning (grep-based, user space)
# ---------------------------------------------------------------------------
echo "===SECTION:malware_signatures==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    echo "---obfuscated_php---"
    # Eval + encoding patterns (common obfuscation)
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -lE '(eval\s*\(\s*(base64_decode|gzinflate|gzuncompress|str_rot13|strrev|hex2bin)|assert\s*\(\s*\$|preg_replace\s*\(.*/e)' \
        2>/dev/null | head -100 || echo "none"

    echo "---known_webshells---"
    # Known webshell signatures
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -lE '(c99shell|r57shell|WSO |FilesMan|b374k|phpspy|webadmin.*shell|Meterpreter|@fsockopen\(|passthru\s*\(|shell_exec\s*\(|system\s*\(\$_(GET|POST|REQUEST)|pcntl_exec)' \
        2>/dev/null | head -100 || echo "none"

    echo "---long_oneliner_php---"
    # PHP files with first line > 5000 chars (obfuscated/encoded payloads)
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} \
        -exec awk 'NR==1 && length>5000 && /^<\?php/ {print FILENAME}' {} + \
        2>/dev/null | head -100 || echo "none"

    echo "---seo_crypto_injections---"
    # SEO spam, redirects, crypto miners in PHP/HTML/JS
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \( -name '*.php' -o -name '*.html' -o -name '*.js' \) ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -lE '(<script[^>]*src=.*(\/min\.js|\/stat\.js|\/analytics\.js|evil|malware)|document\.write\(unescape|String\.fromCharCode|coinhive|cryptonight|eval\(atob)' \
        2>/dev/null | head -100 || echo "none"
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# Cloaked code in image/media files
# Attackers embed PHP, HTML, or JS inside .jpg/.png/.gif/.ico/.svg files.
# These pass extension-based checks but execute when included/required.
# ---------------------------------------------------------------------------
echo "===SECTION:cloaked_images==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    # Directories where images live and PHP should NEVER appear
    _IMG_PATHS=( "*/uploads/*" "*/images/*" "*/img/*" "*/media/*" "*/gallery/*"
                 "*/photos/*" "*/pics/*" "*/assets/*" "*/files/*" "*/content/*" )

    # Build find -path predicates for upload-like dirs
    _IMG_PATH_ARGS=()
    for _ip in "${_IMG_PATHS[@]}"; do
        if [[ ${#_IMG_PATH_ARGS[@]} -eq 0 ]]; then
            _IMG_PATH_ARGS+=( -path "$_ip" )
        else
            _IMG_PATH_ARGS+=( -o -path "$_ip" )
        fi
    done

    echo "---php_in_images---"
    # Image files that contain PHP open tags (<?php, <?=, <? followed by space)
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' \
           -o -iname '*.bmp' -o -iname '*.ico' -o -iname '*.webp' -o -iname '*.svg' \
           -o -iname '*.tiff' -o -iname '*.tif' \) \
        ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -rlP '<\?php|<\?=|<\?\s' 2>/dev/null | head -100 || echo "none"

    echo "---html_in_images---"
    # Image files containing HTML/JS code (like the kanan.jpg case: <!DOCTYPE, <html, <script)
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' \
           -o -iname '*.bmp' -o -iname '*.ico' -o -iname '*.webp' \) \
        ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -rlEi '<!DOCTYPE|<html|<script|<iframe|document\.write|eval\s*\(' \
        2>/dev/null | head -100 || echo "none"

    echo "---double_extension---"
    # Double-extension files: image.php.jpg, shell.jpg.php, etc.
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} \( \
        -iname '*.php.jpg' -o -iname '*.php.jpeg' -o -iname '*.php.png' -o -iname '*.php.gif' \
        -o -iname '*.php.ico' -o -iname '*.php.webp' -o -iname '*.php.bmp' \
        -o -iname '*.jpg.php' -o -iname '*.jpeg.php' -o -iname '*.png.php' -o -iname '*.gif.php' \
        -o -iname '*.ico.php' -o -iname '*.webp.php' -o -iname '*.bmp.php' \
        -o -iname '*.php.svg' -o -iname '*.svg.php' \
        -o -iname '*.phtml.jpg' -o -iname '*.phtml.png' -o -iname '*.phtml.gif' \
        -o -iname '*.jpg.phtml' -o -iname '*.png.phtml' -o -iname '*.gif.phtml' \
        -o -iname '*.php5.jpg' -o -iname '*.php7.jpg' \
        \) -printf '%T@ %s %m %u %p\n' 2>/dev/null | sort -rn | head -100 | \
        $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
    [[ ${PIPESTATUS[0]} -ne 0 ]] || true

    echo "---image_type_mismatch---"
    # Image files in upload-like dirs whose actual content is PHP/text (MIME mismatch)
    # Uses `file` command to detect real type — catches even heavily obfuscated payloads
    if command -v file &>/dev/null; then
        find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \
            \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' \
               -o -iname '*.ico' -o -iname '*.webp' -o -iname '*.bmp' \) \
            \( "${_IMG_PATH_ARGS[@]}" \) \
            ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
            xargs -0 -P2 -n50 file --mime-type 2>/dev/null | \
            grep -viE '(image/|application/octet-stream|cannot open)' | head -100 || echo "none"
    else
        echo "file_command_not_available"
    fi

    echo "---large_images_with_code---"
    # Images in uploads > 500KB that contain suspicious byte sequences
    # (legitimate images rarely contain these ASCII strings)
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -size +500k \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.gif' \) \
        \( "${_IMG_PATH_ARGS[@]}" \) \
        ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -rlP '(eval\s*\(|base64_decode|gzinflate|assert\s*\(|passthru|shell_exec|system\s*\()' \
        2>/dev/null | head -50 || echo "none"
else
    echo "no_scan_dirs_found"
fi

# ---------------------------------------------------------------------------
# All .htaccess files (malware often injects redirects here)
# ---------------------------------------------------------------------------
echo "===SECTION:htaccess==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '.htaccess' ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} \
        -exec echo "---{}---" \; -exec cat {} \; 2>/dev/null | head -5000 || echo "none"
else
    echo "no_scan_dirs_found"
fi

# Crontabs collection
echo "===SECTION:crontabs==="
if [[ -n "$OWNER" ]]; then
    # Owner-scoped: only that user's spool file + system entries mentioning them
    echo "---user_spool---"
    for f in "/var/spool/cron/${OWNER}" "/var/spool/cron/crontabs/${OWNER}"; do
        if [[ -f "$f" ]]; then
            echo "---${f}---"
            cat "$f" 2>/dev/null || echo "unreadable"
        fi
    done
    echo "---etc_crontab_user---"
    grep -n "$OWNER" /etc/crontab 2>/dev/null || echo "no_matches"
    echo "---cron_d_user---"
    for f in /etc/cron.d/*; do
        [[ -f "$f" ]] || continue
        matches=$(grep -c "$OWNER" "$f" 2>/dev/null || echo "0")
        if [[ "$matches" -gt 0 ]]; then
            echo "---${f}---"
            grep -n "$OWNER" "$f" 2>/dev/null
        fi
    done
else
    # No owner: collect everything
    echo "---etc_crontab---"
    cat /etc/crontab 2>/dev/null || echo "not_found"
    echo "---cron_d---"
    for f in /etc/cron.d/*; do
        [[ -f "$f" ]] || continue
        echo "---${f}---"
        cat "$f" 2>/dev/null || echo "unreadable"
    done
    echo "---spool_crontabs---"
    for f in /var/spool/cron/* /var/spool/cron/crontabs/*; do
        [[ -f "$f" ]] || continue
        echo "---${f}---"
        cat "$f" 2>/dev/null || echo "unreadable"
    done
fi
fi # end filesystem

# ---------------------------------------------------------------------------
# 4. Domain Info
# ---------------------------------------------------------------------------

# Function: inspect a single domain given its document root
inspect_domain() {
    local _domain="$1"
    local _docroot="$2"
    echo "---domain:${_domain}---"
    echo "document_root=$_docroot"
    echo "disk_usage=$(du -sh "$_docroot" 2>/dev/null | awk '{print $1}' || echo unknown)"
    echo "cms=$(detect_cms "$_docroot")"

    # WordPress detection
    if [[ -f "${_docroot}/wp-config.php" ]]; then
        echo "wordpress=yes"
        local _wpver
        _wpver=$(grep 'wp_version\s*=' "${_docroot}/wp-includes/version.php" 2>/dev/null | grep -oP "'[^']+'" | tr -d "'" || echo "unknown")
        echo "wp_version=$_wpver"
        local _dbpfx
        _dbpfx=$(grep 'table_prefix' "${_docroot}/wp-config.php" 2>/dev/null | grep -oP "'[^']+'" | head -1 || echo "wp_")
        echo "wp_db_prefix=$_dbpfx"
        local _wpdebug
        _wpdebug=$(grep 'WP_DEBUG' "${_docroot}/wp-config.php" 2>/dev/null | head -1 || echo "not_set")
        echo "wp_debug=$_wpdebug"
    else
        echo "wordpress=no"
    fi

    echo "---docroot_listing:${_domain}---"
    ls -la "$_docroot" 2>/dev/null | head -40

    # WP-CLI checks (only if WordPress detected and wp-cli available)
    if [[ -f "${_docroot}/wp-config.php" ]] && command -v wp &>/dev/null; then
        local -a _wp=(wp "--path=${_docroot}" --no-color --allow-root)
        echo "---wp_verify_checksums:${_domain}---"
        "${_wp[@]}" core verify-checksums 2>&1 | head -200 || echo "unavailable"
        echo "---wp_plugin_list:${_domain}---"
        "${_wp[@]}" plugin list --format=table 2>/dev/null | head -100 || echo "unavailable"
        echo "---wp_theme_list:${_domain}---"
        "${_wp[@]}" theme list --format=table 2>/dev/null | head -50 || echo "unavailable"
        echo "---wp_admin_users:${_domain}---"
        "${_wp[@]}" user list --role=administrator --format=table 2>/dev/null | head -50 || echo "unavailable"
        echo "---wp_cron_events:${_domain}---"
        "${_wp[@]}" cron event list --format=table 2>/dev/null | head -100 || echo "unavailable"
    fi
}

# Function: resolve document root for a domain (original method)
resolve_docroot() {
    local _dom="$1"
    local _dr=""
    # Plesk direct path
    [[ -d "/var/www/vhosts/$_dom/httpdocs" ]] && echo "/var/www/vhosts/$_dom/httpdocs" && return
    [[ -d "/var/www/vhosts/$_dom" ]] && echo "/var/www/vhosts/$_dom" && return
    # DirectAdmin
    local _da_path=$(find /home -maxdepth 4 -path "*/domains/$_dom/public_html" -type d 2>/dev/null | head -1)
    [[ -n "$_da_path" ]] && echo "$_da_path" && return
    # cPanel via /etc/userdomains
    if [[ -f /etc/userdomains ]]; then
        local _cpuser=$(grep "^${_dom}:" /etc/userdomains 2>/dev/null | cut -d: -f2 | xargs)
        if [[ -n "$_cpuser" && -d "/home/$_cpuser/public_html" ]]; then echo "/home/$_cpuser/public_html"; return; fi
    fi
    # Check Apache/httpd configs
    for conf in /etc/apache2/sites-enabled /etc/httpd/conf.d /usr/local/apache/conf/httpd.conf /etc/httpd/conf/httpd.conf /etc/nginx/sites-enabled; do
        if [[ -d "$conf" ]]; then
            _dr=$(grep -rli "$_dom" "$conf" 2>/dev/null | head -1 | xargs grep -iE 'DocumentRoot|root' 2>/dev/null | head -1 | awk '{print $2}' | tr -d '";' || echo "")
        elif [[ -f "$conf" ]]; then
            _dr=$(grep -A10 "$_dom" "$conf" 2>/dev/null | grep -iE 'DocumentRoot|root' | head -1 | awk '{print $2}' | tr -d '";' || echo "")
        fi
        [[ -n "$_dr" && -d "$_dr" ]] && echo "$_dr" && return
    done
    # Fallback: search user home for domain dir
    if [[ -n "$OWNER" ]]; then
        for base in /home /home2 /var/www /var/vhosts; do
            [[ -d "${base}/${OWNER}/public_html" ]] && echo "${base}/${OWNER}/public_html" && return
            [[ -d "${base}/${OWNER}/${_dom}" ]] && echo "${base}/${OWNER}/${_dom}" && return
        done
    fi
    echo ""
}

# Function: discover all domains for an account
discover_account_domains() {
    local _owner="$1"
    local _domains=()
    local _hdir="${HOMEDIR:-}"

    # Try getent if HOMEDIR not set
    if [[ -z "$_hdir" ]]; then
        _hdir=$(getent passwd "$_owner" 2>/dev/null | cut -d: -f6)
    fi

    # cPanel: /var/cpanel/users/$OWNER lists domains
    if [[ -f "/var/cpanel/users/${_owner}" ]]; then
        while IFS= read -r line; do
            _domains+=("$line")
        done < <(grep -oP '(?<=DNS=|DNS\d*=)\S+' "/var/cpanel/users/${_owner}" 2>/dev/null)
    fi

    # Plesk: check vhost.conf paths
    if [[ -d "/var/www/vhosts" ]]; then
        for d in /var/www/vhosts/*/httpdocs; do
            [[ -d "$d" ]] || continue
            local _vdom
            _vdom=$(basename "$(dirname "$d")")
            # Check if owned by this user
            if [[ "$(stat -c '%U' "$d" 2>/dev/null)" == "$_owner" ]]; then
                _domains+=("$_vdom")
            fi
        done
    fi

    # DirectAdmin: /usr/local/directadmin/data/users/$OWNER/domains.list
    if [[ -f "/usr/local/directadmin/data/users/${_owner}/domains.list" ]]; then
        while IFS= read -r line; do
            [[ -n "$line" ]] && _domains+=("$line")
        done < "/usr/local/directadmin/data/users/${_owner}/domains.list"
    fi

    # Fallback: scan home for wp-config.php to find WordPress installs
    if [[ ${#_domains[@]} -eq 0 && -n "$_hdir" && -d "$_hdir" ]]; then
        while IFS= read -r wpconf; do
            local _dr
            _dr=$(dirname "$wpconf")
            local _dname
            _dname=$(basename "$_dr")
            [[ "$_dname" == "public_html" ]] && _dname=$(basename "$(dirname "$_dr")")
            _domains+=("$_dname|$_dr")
        done < <(find "$_hdir" -maxdepth 4 -name 'wp-config.php' -type f 2>/dev/null)
    fi

    # Deduplicate (guard empty array for bash < 4.4 compat)
    if [[ ${#_domains[@]} -gt 0 ]]; then
        printf '%s\n' "${_domains[@]}" | sort -u
    fi
}

