# 10. In-Memory
if _run_section "inmemory"; then
echo "===SECTION:inmemory_malware==="
echo "---deleted_binaries---"
for pid_dir in /proc/[0-9]*; do
    pid="${pid_dir##*/}"; exe_link=$(readlink "${pid_dir}/exe" 2>/dev/null || echo "")
    if [[ "$exe_link" == *"(deleted)"* ]]; then
        cmd=$(tr '\0' ' ' < "${pid_dir}/cmdline" 2>/dev/null | head -c 200 || echo ""); owner_uid=$(awk '/^Uid:/{print $2}' "${pid_dir}/status" 2>/dev/null || echo "?"); owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
        echo "pid=${pid}|exe=${exe_link}|user=${owner_name}|cmd=${cmd}"
    fi
done 2>/dev/null
echo "---dev_shm---"; ls -la /dev/shm/ 2>/dev/null | grep -v '^total' | grep -v '^d' | head -30 || echo "empty"
echo "---memfd_processes---"
for pid_dir in /proc/[0-9]*; do
    pid="${pid_dir##*/}"; found_memfd=""
    for fd in "${pid_dir}/fd"/*; do target=$(readlink "$fd" 2>/dev/null || echo ""); if [[ "$target" == *"/memfd:"* || "$target" == *"memfd:"* ]]; then found_memfd="${found_memfd}${target}; "; fi; done 2>/dev/null
    if [[ -n "$found_memfd" ]]; then
        cmd=$(tr '\0' ' ' < "${pid_dir}/cmdline" 2>/dev/null | head -c 200 || echo ""); owner_uid=$(awk '/^Uid:/{print $2}' "${pid_dir}/status" 2>/dev/null || echo "?"); owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
        echo "pid=${pid}|user=${owner_name}|memfd=${found_memfd}|cmd=${cmd}"
    fi
done 2>/dev/null
echo "---tmp_executables---"
find /tmp -maxdepth 2 -type f \( -perm -u+x -o -name '*.sh' -o -name '*.pl' -o -name '*.py' \) -printf '%T@ %u %s %m %p\n' 2>/dev/null | sort -rn | head -20 | $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
find /tmp -maxdepth 2 -type f -mtime -7 -regex '.*/[a-zA-Z0-9]\{6,\}$' -printf '%T@ %u %s %m %p\n' 2>/dev/null | sort -rn | head -20 | $_AWK '{printf "%s %s %s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3, $4, $5}'
echo "---high_cpu_processes---"
ps -eo pid,user,%cpu,%mem,etime,args --sort=-%cpu 2>/dev/null | awk 'NR==1 || ($3+0 > 5.0 && $2 != "root" && $2 != "mysql" && $2 != "named")' | head -15 || echo "none"
echo "---hicpu_fd_details---"
if [[ -n "$OWNER" ]]; then OWNER_UID=$(id -u "$OWNER" 2>/dev/null || echo ""); fi
for pid in $(ps -eo pid,%cpu,user --sort=-%cpu 2>/dev/null | awk -v ou="${OWNER_UID:-}" 'NR>1 && $2+0 > 10.0 { if (ou == "" || $3 != "root") print $1 }' | head -5); do
    echo "---pid:${pid}---"; exe=$(readlink "/proc/${pid}/exe" 2>/dev/null || echo "unknown"); cmd=$(tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null | head -c 300 || echo "unknown")
    owner_uid=$(awk '/^Uid:/{print $2}' "/proc/${pid}/status" 2>/dev/null || echo "?"); owner_name=$(getent passwd "$owner_uid" 2>/dev/null | cut -d: -f1 || echo "uid:${owner_uid}")
    echo "exe=${exe}"; echo "cmd=${cmd}"; echo "user=${owner_name}"
    grep -vE 'lib(c|pthread|dl|m|rt|nss|resolv|crypt|z\.|ssl|crypto|pcre|xml|curl|gmp|icu)' "/proc/${pid}/maps" 2>/dev/null | grep -v '\[' | awk '{print $NF}' | sort -u | head -20 || echo "maps=unavailable"
    ls -la "/proc/${pid}/fd" 2>/dev/null | grep -v '/dev/null\|/dev/pts\|pipe:\|socket:\|anon_inode' | head -20 || echo "fds=unavailable"
done 2>/dev/null
fi

# 11. Malware Log
if _run_section "malware_log"; then
echo "===SECTION:malware_log_extract==="
if [[ -f /var/log/imunify360/console.log ]]; then
    grep -oP "'[^']+': \{'[^']+': \{'hits': \[\{'matches': '[^']+', '\w+': \w+, '[^']+': \w+, '\w+': \d+\}\], 'size': \d+, 'hash': '[\\w]+'" /var/log/imunify360/console.log 2>/dev/null | tail -3000 || echo "no_matches"
else echo "console_log_not_found"; fi
fi

# 12. Logs
if _run_section "logs"; then
echo "===SECTION:logs==="
grep_pattern=""
if [[ -n "$TARGET_DOMAINS" ]]; then
    grep_pattern="${TARGET_DOMAINS//,/|}"
    echo "Log Filter Active: $grep_pattern"
fi
for logfile in \
    /var/log/imunify360/console.log \
    /var/log/imunify360/debug.log \
    /var/log/imunify360/network.log \
    /var/log/imunify360/error.log \
    /var/log/imunify360-webshield/access.log \
    /var/log/imunify360-webshield/error.log \
    /var/log/ossec/logs/alerts/alerts.log \
    /var/log/ossec/logs/active-responses.log \
    /var/log/i360deploy.log \
    /var/log/imav-deploy.log \
    /usr/local/directadmin/custombuild/custombuild.log \
    /var/log/patchman/patchman.log \
    /usr/local/apache/logs/error_log \
    /usr/local/apache/logs/access_log \
    /usr/local/apache/logs/modsec_audit.log \
    /etc/apache2/logs/modsec_audit.log \
    /var/log/httpd/modsec_audit.log \
    /var/log/httpd/error_log \
    /var/log/httpd/access_log \
    /var/log/nginx/error.log \
    /var/log/nginx/access.log \
    /var/www/vhosts/system/*/logs/error_log; do
    
    [[ -f "$logfile" ]] || continue
    echo "---${logfile}---"
    if [[ -n "$grep_pattern" ]]; then
        grep -E "$grep_pattern" "$logfile" 2>/dev/null | tail -n 3000 || echo "no_matches"
    else
        tail -n 3000 "$logfile" 2>/dev/null || echo "not_found_or_empty"
    fi
done
fi

# 13. TARGET SUMMARY (NEW SECTION)
echo ""
echo "===SECTION:target_summary==="
echo "Timestamp: $(date -u)"
if [[ -z "$TARGET_DOMAINS" ]]; then
    echo "No specific domains targeted for Summary. Pass --domains or --domain to use this feature."
else
    echo "----------------------------------------------------------------------------------------------------"
    printf "%-30s | %-25s | %-40s\n" "DOMAIN/PATH" "APPLICATION" "LOCATION"
    echo "----------------------------------------------------------------------------------------------------"
    IFS=',' read -ra DOM_ARRAY <<< "$TARGET_DOMAINS"
    for d in "${DOM_ARRAY[@]}"; do
        d=$(echo "$d" | xargs)
        docroot=$(resolve_docroot "$d")
        if [[ "$docroot" == "NOT_FOUND" ]]; then
            app_type="Path not found"
        else
            app_type=$(detect_cms "$docroot")
        fi
        printf "%-30s | %-25s | %-40s\n" "$d" "$app_type" "$docroot"
        if [[ "$docroot" != "NOT_FOUND" ]]; then scan_nested_apps "$docroot"; fi
    done
    echo "----------------------------------------------------------------------------------------------------"
fi

echo "===SECTION:done==="
echo "collector_finished=ok"
echo "timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null)"
