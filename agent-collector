#!/bin/bash
# ============================================================================
# im360_forensic_collector_v10.sh
#
# FIXES:
# - Moved all Function Definitions to the HEADER.
# - Solves "command not found" errors for resolve_docroot/detect_cms.
# - Preserves all original forensic logic (Filesystem, DB, Memory, Logs).
#
# Usage:
#   bash collector.sh --domains "example.com" --no-dry-run
# ============================================================================

# NOTE: -e is intentionally omitted. This collector must run to completion.
set -uo pipefail

# --- Variables ---
OWNER=""
DOMAIN=""
TARGET_DOMAINS=""
OUTFILE=""
DRY_RUN="false"
SECTIONS=""
HOMEDIR=""

# Detect awk variant
if command -v gawk &>/dev/null; then
    _AWK=gawk
elif awk 'BEGIN{exit (strftime("%Y",0)=="1970"?0:1)}' 2>/dev/null; then
    _AWK=awk
else
    _AWK=awk
    echo "WARNING: gawk not found — timestamps will be raw epoch values" >&2
fi

# ============================================================================
# 1. CORE FUNCTION DEFINITIONS (Must be at the top)
# ============================================================================

show_help() {
    echo "Usage: ./collector.sh [OPTIONS]"
    echo "  --no-dry-run          Execute full scan (Required)."
    echo "  --domains <LIST>      Filter logs & summary for specific domains (comma-separated)."
    echo "  --domain <DOMAIN>     Target a single domain."
    echo "  --owner <USER>        Target a specific system user."
    echo "  --out <FILE>          Save output to file."
    exit 0
}

resolve_docroot() {
    local domain="$1"
    # 1. PLESK
    if [[ -d "/var/www/vhosts/$domain/httpdocs" ]]; then echo "/var/www/vhosts/$domain/httpdocs"; return; fi
    if [[ -d "/var/www/vhosts/$domain" ]]; then echo "/var/www/vhosts/$domain"; return; fi
    # 2. DIRECTADMIN
    local da_path=$(find /home -maxdepth 4 -path "*/domains/$domain/public_html" -type d 2>/dev/null | head -1)
    if [[ -n "$da_path" ]]; then echo "$da_path"; return; fi
    # 3. cPANEL
    if [[ -f /etc/userdomains ]]; then
        local user=$(grep "^${domain}:" /etc/userdomains | cut -d: -f2 | xargs)
        if [[ -n "$user" ]]; then
             if [[ -d "/home/$user/public_html" ]]; then echo "/home/$user/public_html"; return; fi
        fi
    fi
    # 4. FASTPANEL
    local fp_path=$(find /var/www -maxdepth 4 -path "*/data/www/$domain" -type d 2>/dev/null | head -1)
    if [[ -n "$fp_path" ]]; then echo "$fp_path"; return; fi
    # 5. Fallback/Generic
    if [[ -d "/var/www/$domain/public_html" ]]; then echo "/var/www/$domain/public_html"; return; fi
    if [[ -d "/var/www/html/$domain" ]]; then echo "/var/www/html/$domain"; return; fi
    # 6. Config Grep (Last Resort)
    for conf in /etc/apache2/sites-enabled /etc/httpd/conf/httpd.conf /etc/nginx/sites-enabled /usr/local/apache/conf/httpd.conf; do
        if [[ -e "$conf" ]]; then
            local path=$(grep -rA10 "$domain" "$conf" 2>/dev/null | grep -iE "DocumentRoot|root" | head -1 | awk '{print $2}' | tr -d '";')
            if [[ -n "$path" && -d "$path" ]]; then echo "$path"; return; fi
        fi
    done
    echo "NOT_FOUND"
}

detect_cms() {
    local dir="$1"
    [[ ! -d "$dir" ]] && echo "Invalid Path" && return
    if [[ -f "$dir/wp-config.php" ]]; then
        local ver="Unknown"
        [[ -f "$dir/wp-includes/version.php" ]] && ver=$(grep "wp_version =" "$dir/wp-includes/version.php" | cut -d"'" -f2)
        echo "WordPress (v$ver)"; return
    fi
    if [[ -f "$dir/configuration.php" && -d "$dir/administrator" ]]; then echo "Joomla"; return; fi
    if [[ -f "$dir/config/settings.inc.php" || -f "$dir/app/config/parameters.php" ]]; then echo "PrestaShop"; return; fi
    if [[ -f "$dir/app/etc/env.php" || -f "$dir/app/etc/local.xml" ]]; then echo "Magento"; return; fi
    if [[ -f "$dir/artisan" && -d "$dir/app" ]]; then echo "Laravel"; return; fi
    if [[ -f "$dir/sites/default/settings.php" ]]; then echo "Drupal"; return; fi
    if [[ -f "$dir/config.php" && -d "$dir/admin" ]]; then echo "OpenCart"; return; fi
    echo "Unknown/Custom"
}

scan_nested_apps() {
    local root="$1"
    # Deep crawl (level 6) skipping heavy folders
    find "$root" -maxdepth 6 \
        \( -name "wp-config.php" -o -name "configuration.php" -o -name "artisan" -o -name "env.php" -o -name "settings.inc.php" \) \
        ! -path "*/vendor/*" ! -path "*/node_modules/*" ! -path "*/cache/*" ! -path "*/.git/*" \
        -print0 2>/dev/null | while IFS= read -r -d '' file; do
        local app_dir=$(dirname "$file")
        if [[ "$app_dir" == "$root" ]]; then continue; fi
        local child_type=$(detect_cms "$app_dir")
        local rel_path="${app_dir#$root}"
        if [[ "$child_type" != "Unknown/Custom" ]]; then
             printf "   |__ [NESTED] %-20s | %-40s\n" "$child_type" "$rel_path"
        fi
    done
}

inspect_domain() {
    local _domain="$1"
    local _docroot="$2"
    echo "---domain:${_domain}---"
    echo "document_root=$_docroot"
    echo "disk_usage=$(du -sh "$_docroot" 2>/dev/null | awk '{print $1}' || echo unknown)"
    if [[ -f "${_docroot}/wp-config.php" ]]; then
        echo "wordpress=yes"
        local _wpver=$(grep 'wp_version\s*=' "${_docroot}/wp-includes/version.php" 2>/dev/null | grep -oP "'[^']+'" | tr -d "'" || echo "unknown")
        echo "wp_version=$_wpver"
        local _dbpfx=$(grep 'table_prefix' "${_docroot}/wp-config.php" 2>/dev/null | grep -oP "'[^']+'" | head -1 || echo "wp_")
        echo "wp_db_prefix=$_dbpfx"
        local _wpdebug=$(grep 'WP_DEBUG' "${_docroot}/wp-config.php" 2>/dev/null | head -1 || echo "not_set")
        echo "wp_debug=$_wpdebug"
    else
        echo "wordpress=no"
    fi
    echo "---docroot_listing:${_domain}---"
    ls -la "$_docroot" 2>/dev/null | head -40
    if [[ -f "${_docroot}/wp-config.php" ]] && command -v wp &>/dev/null; then
        local -a _wp=(wp "--path=${_docroot}" --no-color --allow-root)
        echo "---wp_verify_checksums:${_domain}---"
        "${_wp[@]}" core verify-checksums 2>&1 | head -200 || echo "unavailable"
        echo "---wp_plugin_list:${_domain}---"
        "${_wp[@]}" plugin list --format=table 2>/dev/null | head -100 || echo "unavailable"
        echo "---wp_theme_list:${_domain}---"
        "${_wp[@]}" theme list --format=table 2>/dev/null | head -50 || echo "unavailable"
        echo "---wp_admin_users:${_domain}---"
        "${_wp[@]}" user list --role=administrator --format=table 2>/dev/null | head -50 || echo "unavailable"
        echo "---wp_cron_events:${_domain}---"
        "${_wp[@]}" cron event list --format=table 2>/dev/null | head -100 || echo "unavailable"
    fi
}

discover_account_domains() {
    local _owner="$1"
    local _domains=()
    local _hdir="${HOMEDIR:-}"
    if [[ -z "$_hdir" ]]; then _hdir=$(getent passwd "$_owner" 2>/dev/null | cut -d: -f6); fi
    if [[ -f "/var/cpanel/users/${_owner}" ]]; then
        while IFS= read -r line; do _domains+=("$line"); done < <(grep -oP '(?<=DNS=|DNS\d*=)\S+' "/var/cpanel/users/${_owner}" 2>/dev/null)
    fi
    if [[ -d "/var/www/vhosts" ]]; then
        for d in /var/www/vhosts/*/httpdocs; do
            [[ -d "$d" ]] || continue
            local _vdom=$(basename "$(dirname "$d")")
            if [[ "$(stat -c '%U' "$d" 2>/dev/null)" == "$_owner" ]]; then _domains+=("$_vdom"); fi
        done
    fi
    if [[ -f "/usr/local/directadmin/data/users/${_owner}/domains.list" ]]; then
        while IFS= read -r line; do [[ -n "$line" ]] && _domains+=("$line"); done < "/usr/local/directadmin/data/users/${_owner}/domains.list"
    fi
    if [[ ${#_domains[@]} -eq 0 && -n "$_hdir" && -d "$_hdir" ]]; then
        while IFS= read -r wpconf; do
            local _dr=$(dirname "$wpconf")
            local _dname=$(basename "$_dr")
            [[ "$_dname" == "public_html" ]] && _dname=$(basename "$(dirname "$_dr")")
            _domains+=("$_dname|$_dr")
        done < <(find "$_hdir" -maxdepth 4 -name 'wp-config.php' -type f 2>/dev/null)
    fi
    if [[ ${#_domains[@]} -gt 0 ]]; then printf '%s\n' "${_domains[@]}" | sort -u; fi
}

_run_section() {
    [[ -z "$SECTIONS" ]] && return 0
    local section="$1"
    local IFS=','
    for s in $SECTIONS; do
        [[ "$s" == "$section" ]] && return 0
    done
    return 1
}

# ============================================================================
# 2. ARGUMENT PARSING
# ============================================================================
while [[ $# -gt 0 ]]; do
    case "$1" in
        --owner)      [[ $# -ge 2 ]] && OWNER="$2" && shift 2 || { echo "ERROR: --owner requires a value" >&2; shift; } ;;
        --domain)     [[ $# -ge 2 ]] && DOMAIN="$2" && shift 2 || { echo "ERROR: --domain requires a value" >&2; shift; } ;;
        --domains)    [[ $# -ge 2 ]] && TARGET_DOMAINS="$2" && shift 2 || { echo "ERROR: --domains requires a value" >&2; shift; } ;;
        --out)        [[ $# -ge 2 ]] && OUTFILE="$2" && shift 2 || { echo "ERROR: --out requires a value" >&2; shift; } ;;
        --sections)   [[ $# -ge 2 ]] && SECTIONS="$2" && shift 2 || { echo "ERROR: --sections requires a value" >&2; shift; } ;;
        --no-dry-run) DRY_RUN="false"; shift ;;
        --dry-run)    DRY_RUN="true"; shift ;;
        --help|-h)    show_help ;;
        *)            shift ;;
    esac
done

# Merge single domain into target list if present
if [[ -n "$DOMAIN" ]]; then
    if [[ -n "$TARGET_DOMAINS" ]]; then TARGET_DOMAINS="$TARGET_DOMAINS,$DOMAIN"; else TARGET_DOMAINS="$DOMAIN"; fi
fi

# If --out is set, redirect all subsequent stdout to that file
if [[ -n "$OUTFILE" ]]; then
    exec > "$OUTFILE"
    echo "Writing output to $OUTFILE" >&2
fi

# ---------------------------------------------------------------------------
# Dry-run mode
# ---------------------------------------------------------------------------
if [[ "$DRY_RUN" == "true" ]]; then
    echo "===SECTION:dry_run==="
    echo "mode=dry_run"
    echo "message=Pass --no-dry-run to execute. Pass --help for options."
    echo "hostname=$(hostname 2>/dev/null || echo unknown)"
    echo "current_time=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null || echo unknown)"
    echo "---w---"
    w 2>/dev/null || echo "w_unavailable"
    echo "===SECTION:done==="
    exit 0
fi

# ============================================================================
# 3. FORENSIC EXECUTION START
# ============================================================================

# 1. System Information
echo "===SECTION:system==="
echo "hostname=$(hostname 2>/dev/null || echo unknown)"
echo "kernel=$(uname -r 2>/dev/null || echo unknown)"
echo "arch=$(uname -m 2>/dev/null || echo unknown)"
echo "os=$(cat /etc/redhat-release 2>/dev/null || grep -m1 '^PRETTY_NAME=' /etc/os-release 2>/dev/null | cut -d= -f2- | tr -d '"' || echo unknown)"
echo "uptime=$(uptime -p 2>/dev/null || uptime 2>/dev/null || echo unknown)"
echo "load=$(cat /proc/loadavg 2>/dev/null || echo unknown)"
echo "current_time=$(date -u '+%Y-%m-%d %H:%M:%S UTC' 2>/dev/null || echo unknown)"

# 2. Imunify360 Agent
if _run_section "imunify"; then
echo "===SECTION:imunify==="
if command -v imunify360-agent &>/dev/null; then
    echo "installed=yes"
    imunify360-agent version 2>/dev/null || echo "version=unknown"
    echo "---features---"
    imunify360-agent features list 2>/dev/null || echo "features=unavailable"
    echo "---config---"
    imunify360-agent config show 2>/dev/null | head -80 || echo "config=unavailable"
    echo "---signature_db---"
    cat /var/imunify360/files/sigs/v1/description.json 2>/dev/null || echo "not_found"
    echo "---default_action---"
    imunify360-agent config show -v --json 2>/dev/null | grep default_action || echo "unavailable"
    echo "---sends_file_for_analysis---"
    imunify360-agent config show -v --json 2>/dev/null | grep sends_file_for_analysis || echo "unavailable"
    echo "---proactive_defense---"
    grep PROACTIVE -A5 /etc/sysconfig/imunify360/imunify360-merged.config 2>/dev/null || echo "unavailable"
    echo "---install_date---"
    head -20 /var/log/i360deploy.log 2>/dev/null || echo "not_found"
else
    echo "installed=no"
fi
fi

# 3. Discover Accounts
echo "===SECTION:accounts==="
_SYS_EXACT='root|bin|daemon|adm|lp|sync|shutdown|halt|mail|operator|games|ftp|nobody|dbus|polkitd|sshd|postfix|chrony|ntp|nscd|tcpdump|avahi|mysql|mysqld|postgres|redis|memcached|mongodb|nginx|apache|httpd|www-data|lighttpd|named|dovecot|cyrus|exim|mailman|mailnull|smmsp|clamav|clamupdate|amavis|opendkim|whm|softaculous|solr|tomcat|prosody|varnish|haproxy|plesk|psa|drweb|imunify360|imav-hoster|roundcube|psaadm|psaftp|git|svn|puppet|chef|docker|libvirt|qemu|virtuser|lsadm|litespeed|lscpd|nfsnobody|rpc|rpcuser|saslauth|abrt|setroubleshoot|sssd|gdm|unbound|gluster|ovirt|zabbix|nagios|prometheus|grafana|node_exporter|elasticsearch|kibana|logstash|jenkins|gitlab|deployer|ansible|ec2-user|centos|ubuntu|cloud-user|oprofile'
_SYS_PREFIX='systemd-|cpanel|ossec|_imunify|imunify360-|sw-cp-|sw-engine|gnome-initial'

declare -a ALL_ACCOUNTS=()
_acct_count=0

while IFS=: read -r _uname _ _uid _ _ _uhome _; do
    [[ -z "$_uname" ]] && continue
    [[ "$_uid" -lt 500 ]] 2>/dev/null && continue
    echo "$_uname" | grep -qE "^(${_SYS_EXACT})$" && continue
    echo "$_uname" | grep -qE "^(${_SYS_PREFIX})" && continue
    [[ -z "$_uhome" || "$_uhome" == "/" || "$_uhome" == "/bin"* || "$_uhome" == "/sbin"* || "$_uhome" == "/usr"* || "$_uhome" == "/dev"* ]] && continue
    _docroot=""
    for _dr_cand in "${_uhome}/public_html" "${_uhome}/httpdocs" "${_uhome}/htdocs" "${_uhome}/www" "${_uhome}/web" "${_uhome}/public"; do
        if [[ -d "$_dr_cand" ]]; then _docroot="$_dr_cand"; break; fi
    done
    if [[ -z "$_docroot" && -d "/var/www/vhosts" ]]; then
        for _vd in /var/www/vhosts/*/httpdocs; do
            [[ -d "$_vd" ]] || continue
            if [[ "$(stat -c '%U' "$_vd" 2>/dev/null)" == "$_uname" ]]; then _docroot="$_vd"; break; fi
        done
    fi
    _wp="no"
    if [[ -n "$_docroot" && -f "${_docroot}/wp-config.php" ]]; then _wp="yes"; fi
    echo "account=${_uname}|uid=${_uid}|home=${_uhome}|docroot=${_docroot:-none}|wordpress=${_wp}|home_exists=$([[ -d "$_uhome" ]] && echo yes || echo no)"
    ALL_ACCOUNTS+=("$_uname")
    _acct_count=$((_acct_count + 1))
done < <(getent passwd 2>/dev/null)

if [[ -d /var/cpanel/users ]]; then
    for _cpf in /var/cpanel/users/*; do
        [[ -f "$_cpf" ]] || continue
        _cpuser=$(basename "$_cpf")
        printf '%s\n' "${ALL_ACCOUNTS[@]}" 2>/dev/null | grep -qx "$_cpuser" && continue
        _cphome=""
        for _base in /home /home2; do
            [[ -d "${_base}/${_cpuser}" ]] && _cphome="${_base}/${_cpuser}" && break
        done
        [[ -z "$_cphome" ]] && continue
        _docroot=""
        [[ -d "${_cphome}/public_html" ]] && _docroot="${_cphome}/public_html"
        _wp="no"
        [[ -n "$_docroot" && -f "${_docroot}/wp-config.php" ]] && _wp="yes"
        echo "account=${_cpuser}|uid=cpanel|home=${_cphome}|docroot=${_docroot:-none}|wordpress=${_wp}|home_exists=yes"
        ALL_ACCOUNTS+=("$_cpuser")
        _acct_count=$((_acct_count + 1))
    done
fi
echo "total_accounts=${_acct_count}"

# 4. WordPress Sites
echo "===SECTION:wordpress_sites==="
_wp_count=0
_discover_wp_sites() {
    local _acctname="$1"
    local _searchdir="$2"
    [[ -d "$_searchdir" ]] || return
    while IFS= read -r _wpcfg; do
        [[ -z "$_wpcfg" ]] && continue
        local _wpdir=$(dirname "$_wpcfg")
        local _ver="unknown"
        if [[ -f "${_wpdir}/wp-includes/version.php" ]]; then
            _ver=$(grep -oP "\\\$wp_version\s*=\s*'[^']+'" "${_wpdir}/wp-includes/version.php" 2>/dev/null | grep -oP "'[^']+'" | tr -d "'" || echo "unknown")
            [[ -z "$_ver" ]] && _ver="unknown"
        fi
        local _active="yes"
        [[ ! -f "${_wpdir}/wp-settings.php" ]] && _active="partial"
        local _dbpfx=$(grep -m1 'table_prefix' "$_wpcfg" 2>/dev/null | grep -oP "'[^']+'" | head -1 | tr -d "'" || echo "wp_")
        [[ -z "$_dbpfx" ]] && _dbpfx="wp_"
        echo "wp_site=${_acctname}|path=${_wpdir}|version=${_ver}|db_prefix=${_dbpfx}|active=${_active}"
        _wp_count=$((_wp_count + 1))
    done < <(find "$_searchdir" -maxdepth 5 -name 'wp-config.php' -type f 2>/dev/null)
}
if [[ -n "$OWNER" ]]; then
    _ownerhome=""
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then _ownerhome="$HOMEDIR"; else
        for _base in /home /home2 /var/www /var/vhosts; do
            [[ -d "${_base}/${OWNER}" ]] && _ownerhome="${_base}/${OWNER}" && break
        done
    fi
    if [[ -n "$_ownerhome" ]]; then _discover_wp_sites "$OWNER" "$_ownerhome"; fi
elif [[ ${#ALL_ACCOUNTS[@]} -gt 0 ]]; then
    while IFS=: read -r _uname _ _ _ _ _uhome _; do
        [[ -z "$_uname" || -z "$_uhome" ]] && continue
        printf '%s\n' "${ALL_ACCOUNTS[@]}" 2>/dev/null | grep -qx "$_uname" || continue
        _discover_wp_sites "$_uname" "$_uhome"
        [[ $_wp_count -ge 200 ]] && echo "truncated_at_200" && break
    done < <(getent passwd 2>/dev/null)
fi
echo "total_wp_sites=${_wp_count}"

# 5. User / Account Info
if _run_section "user_info"; then
echo "===SECTION:user_info==="
if [[ -n "$OWNER" ]]; then
    echo "owner=$OWNER"
    HOMEDIR=""
    for base in /home /home2 /var/www /var/vhosts; do
        if [[ -d "${base}/${OWNER}" ]]; then HOMEDIR="${base}/${OWNER}"; break; fi
    done
    if [[ -z "$HOMEDIR" ]]; then HOMEDIR=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6); HOMEDIR="${HOMEDIR:-}"; fi
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        echo "home=$HOMEDIR"
        echo "disk_usage=$(du -sh "$HOMEDIR" 2>/dev/null | awk '{print $1}' || echo unknown)"
        echo "---home_listing---"
        ls -la "$HOMEDIR" 2>/dev/null | head -50
    else
        echo "home=not_found"
    fi
    echo "---crontab---"
    crontab -l -u "$OWNER" 2>/dev/null || echo "no_crontab"
    echo "---recent_php_files---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        find "$HOMEDIR" -name '*.php' -mtime -7 -type f ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -60 | $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    fi
    echo "---suspicious_files---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        find "$HOMEDIR" -type f -name '*.php' \( -path '*/uploads/*' -o -path '*/upload/*' -o -path '*/tmp/*' \) -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -30 | $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
        find "$HOMEDIR" -maxdepth 4 -type f -path '*/.*/*' ! -path '*/.git/*' ! -path '*/.npm/*' ! -path '*/.cache/*' ! -path '*/.cpanel/*' ! -path '*/.local/*' ! -path '*/.config/*' ! -path '*/.composer/*' ! -path '*/.wp-cli/*' -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -30 | $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    fi
    echo "---world_writable---"
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then
        find "$HOMEDIR" -maxdepth 5 -type f -perm -o+w ! -path '*/cache/*' ! -path '*/tmp/*' ! -path '*/logs/*' -printf '%m %s %p\n' 2>/dev/null | head -30
    fi
else
    echo "owner=not_specified"
fi
fi

# Resolve HOMEDIR if not set
if [[ -n "$OWNER" && -z "$HOMEDIR" ]]; then
    for _base in /home /home2 /var/www /var/vhosts; do
        if [[ -d "${_base}/${OWNER}" ]]; then HOMEDIR="${_base}/${OWNER}"; break; fi
    done
    if [[ -z "$HOMEDIR" ]]; then HOMEDIR=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6); HOMEDIR="${HOMEDIR:-}"; fi
fi

# Build SCAN_DIRS
SCAN_DIRS=()
OWNER_FILTER=()
if [[ -n "$OWNER" ]]; then
    OWNER_FILTER=(-user "$OWNER")
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then SCAN_DIRS=("$HOMEDIR"); else
        _hdir=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
        if [[ -n "$_hdir" && -d "$_hdir" ]]; then SCAN_DIRS=("$_hdir"); fi
    fi
else
    for _base in /home /home2 /var/www /var/vhosts; do
        [[ -d "$_base" ]] && SCAN_DIRS+=("$_base")
    done
fi

# 6. Filesystem Scans
if _run_section "filesystem"; then
echo "===SECTION:hidden_files==="
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    echo "---hidden_files_recent---"
