#!/bin/bash
# ============================================================================
# im360_forensic_collector_v14_FINAL.sh
#
# COMPLETE & FIXED VERSION
# - Output: Markdown (.md) with JSON Summary.
# - Integrity: Read-Only.
# - Logic: Universal Path Resolver + Fixed Nested App Discovery.
#
# Usage:
#   bash collector.sh --domains "dnschaos.online" --no-dry-run --out report.md
# ============================================================================

set -uo pipefail

# --- Variables ---
OWNER=""
DOMAIN=""
TARGET_DOMAINS=""
OUTFILE=""
DRY_RUN="false"
SECTIONS=""
HOMEDIR=""

# Detect awk variant
if command -v gawk &>/dev/null; then _AWK=gawk;
elif awk 'BEGIN{exit (strftime("%Y",0)=="1970"?0:1)}' 2>/dev/null; then _AWK=awk;
else _AWK=awk; echo "WARNING: gawk not found" >&2; fi

# ============================================================================
# 1. CORE FUNCTIONS (DEFINED FIRST TO PREVENT ERRORS)
# ============================================================================

show_help() {
    echo "Usage: ./collector.sh [OPTIONS]"
    echo "  --no-dry-run          Execute full scan (Required)."
    echo "  --domains <LIST>      Filter logs & summary for specific domains."
    echo "  --out <FILE>          Save output (e.g. report.md)."
    exit 0
}

resolve_docroot() {
    local domain="$1"
    # Plesk
    if [[ -d "/var/www/vhosts/$domain/httpdocs" ]]; then echo "/var/www/vhosts/$domain/httpdocs"; return; fi
    if [[ -d "/var/www/vhosts/$domain" ]]; then echo "/var/www/vhosts/$domain"; return; fi
    # DirectAdmin
    local da_path=$(find /home -maxdepth 4 -path "*/domains/$domain/public_html" -type d 2>/dev/null | head -1)
    if [[ -n "$da_path" ]]; then echo "$da_path"; return; fi
    # cPanel
    if [[ -f /etc/userdomains ]]; then
        local user=$(grep "^${domain}:" /etc/userdomains | cut -d: -f2 | xargs)
        if [[ -n "$user" ]]; then
             if [[ -d "/home/$user/public_html" ]]; then echo "/home/$user/public_html"; return; fi
        fi
    fi
    # Generic
    if [[ -d "/var/www/$domain/public_html" ]]; then echo "/var/www/$domain/public_html"; return; fi
    # Fallback Config Grep
    for conf in /etc/apache2/sites-enabled /etc/httpd/conf/httpd.conf /etc/nginx/sites-enabled; do
        if [[ -e "$conf" ]]; then
            local path=$(grep -rA10 "$domain" "$conf" 2>/dev/null | grep -iE "DocumentRoot|root" | head -1 | awk '{print $2}' | tr -d '";')
            if [[ -n "$path" && -d "$path" ]]; then echo "$path"; return; fi
        fi
    done
    echo "NOT_FOUND"
}

detect_cms() {
    local dir="$1"
    [[ ! -d "$dir" ]] && echo "Invalid Path" && return
    if [[ -f "$dir/wp-config.php" ]]; then
        local ver="Unknown"
        [[ -f "$dir/wp-includes/version.php" ]] && ver=$(grep "wp_version =" "$dir/wp-includes/version.php" | cut -d"'" -f2)
        echo "WordPress (v$ver)"; return
    fi
    if [[ -f "$dir/configuration.php" && -d "$dir/administrator" ]]; then echo "Joomla"; return; fi
    if [[ -f "$dir/config/settings.inc.php" ]]; then echo "PrestaShop"; return; fi
    if [[ -f "$dir/app/etc/env.php" ]]; then echo "Magento"; return; fi
    if [[ -f "$dir/artisan" ]]; then echo "Laravel"; return; fi
    if [[ -f "$dir/config.php" && -d "$dir/admin" ]]; then echo "OpenCart"; return; fi
    echo "Unknown/Custom"
}

scan_nested_apps_json() {
    local root="$1"
    local json_items=""
    
    # Process Substitution Fix: < <(find ...) ensures variables persist after loop
    while IFS= read -r -d '' file; do
        local app_dir=$(dirname "$file")
        if [[ "$app_dir" == "$root" ]]; then continue; fi
        if [[ "$app_dir/" == "$root/" ]]; then continue; fi

        local child_type=$(detect_cms "$app_dir")
        local rel_path="${app_dir#$root}"
        
        if [[ "$child_type" != "Unknown/Custom" ]]; then
             if [[ -n "$json_items" ]]; then json_items="$json_items, "; fi
             json_items="$json_items{ \"app\": \"$child_type\", \"path\": \"$rel_path\" }"
        fi
    done < <(find "$root" -maxdepth 5 \( -name "wp-config.php" -o -name "configuration.php" -o -name "artisan" -o -name "config.php" \) ! -path "*/vendor/*" ! -path "*/cache/*" ! -path "*/wp-includes/*" -print0 2>/dev/null)
    
    echo "$json_items"
}

_run_section() {
    [[ -z "$SECTIONS" ]] && return 0
    local section="$1"
    local IFS=','
    for s in $SECTIONS; do [[ "$s" == "$section" ]] && return 0; done
    return 1
}

# ============================================================================
# 2. ARGUMENT PARSING
# ============================================================================
while [[ $# -gt 0 ]]; do
    case "$1" in
        --owner)      [[ $# -ge 2 ]] && OWNER="$2" && shift 2 || { echo "ERROR: --owner requires a value" >&2; shift; } ;;
        --domain)     [[ $# -ge 2 ]] && DOMAIN="$2" && shift 2 || { echo "ERROR: --domain requires a value" >&2; shift; } ;;
        --domains)    [[ $# -ge 2 ]] && TARGET_DOMAINS="$2" && shift 2 || { echo "ERROR: --domains requires a value" >&2; shift; } ;;
        --out)        [[ $# -ge 2 ]] && OUTFILE="$2" && shift 2 || { echo "ERROR: --out requires a value" >&2; shift; } ;;
        --sections)   [[ $# -ge 2 ]] && SECTIONS="$2" && shift 2 || { echo "ERROR: --sections requires a value" >&2; shift; } ;;
        --no-dry-run) DRY_RUN="false"; shift ;;
        --dry-run)    DRY_RUN="true"; shift ;;
        --help|-h)    show_help ;;
        *)            shift ;;
    esac
done

if [[ -n "$DOMAIN" ]]; then
    if [[ -n "$TARGET_DOMAINS" ]]; then TARGET_DOMAINS="$TARGET_DOMAINS,$DOMAIN"; else TARGET_DOMAINS="$DOMAIN"; fi
fi

if [[ -n "$OUTFILE" ]]; then exec > "$OUTFILE"; echo "Writing output to $OUTFILE" >&2; fi

if [[ "$DRY_RUN" == "true" ]]; then
    echo "## Dry Run"
    echo "Pass --no-dry-run to execute. Pass --help for options."
    exit 0
fi

# ============================================================================
# 3. MAIN FORENSIC EXECUTION (Markdown Formatted)
# ============================================================================

echo "# Forensic Report"
echo "**Date:** $(date -u)"
echo "**Hostname:** $(hostname)"
echo ""

# --- System ---
echo "## 1. System Information"
echo "\`\`\`text"
echo "kernel=$(uname -r)"
echo "load=$(cat /proc/loadavg)"
echo "uptime=$(uptime -p)"
echo "\`\`\`"
echo ""

# --- Imunify ---
if _run_section "imunify"; then
echo "## 2. Imunify360 Status"
echo "\`\`\`text"
if command -v imunify360-agent &>/dev/null; then
    imunify360-agent version 2>/dev/null
    echo "--- Config Snippet ---"
    imunify360-agent config show 2>/dev/null | head -20
else
    echo "Not Installed"
fi
echo "\`\`\`"
echo ""
fi

# --- User Info ---
if _run_section "user_info"; then
echo "## 3. User & Account Info"
echo "\`\`\`text"
if [[ -n "$OWNER" ]]; then
    echo "Owner: $OWNER"
    HOMEDIR=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
    echo "Home: $HOMEDIR"
    echo "--- Crontab ---"
    crontab -l -u "$OWNER" 2>/dev/null || echo "No crontab found"
else
    echo "No specific owner targeted. Skipping single-user details."
fi
echo "\`\`\`"
echo ""
fi

# --- Setup Scan Dirs ---
SCAN_DIRS=()
OWNER_FILTER=()
if [[ -n "$OWNER" ]]; then
    OWNER_FILTER=(-user "$OWNER")
    if [[ -n "$HOMEDIR" && -d "$HOMEDIR" ]]; then SCAN_DIRS=("$HOMEDIR"); else
        _hdir=$(getent passwd "$OWNER" 2>/dev/null | cut -d: -f6)
        if [[ -n "$_hdir" && -d "$_hdir" ]]; then SCAN_DIRS=("$_hdir"); fi
    fi
else
    # Global Scan Roots
    for _base in /home /home2 /var/www /var/vhosts /usr/local/apache/htdocs; do
        [[ -d "$_base" ]] && SCAN_DIRS+=("$_base")
    done
fi

# --- Filesystem Scans (THE BIG BLOCK) ---
if _run_section "filesystem"; then
echo "## 4. Filesystem Forensics"
if [[ ${#SCAN_DIRS[@]} -gt 0 ]]; then
    
    echo "### A. Hidden Files (Recent 30 days)"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 6 -type f -name '.*' -mtime -30 \
        ! -path '*/.git/*' ! -path '*/.npm/*' ! -path '*/.cache/*' ! -path '*/.cpanel/*' \
        ! -path '*/.ssh/*' ! -path '*/.pki/*' ! -path '*/.cagefs/*' ! -path '*/.trash/*' \
        -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -100 | \
        $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    echo "\`\`\`"

    echo "### B. Recent PHP Modifications (7 days)"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' -mtime -7 \
        ! -path '*/cache/*' ! -path '*/vendor/*' ! -path '*/node_modules/*' \
        -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -100 | \
        $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    echo "\`\`\`"

    echo "### C. PHP Files in Uploads (High Risk)"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 10 -type f -name '*.php*' \
        \( -path '*/uploads/*' -o -path '*/wp-content/uploads/*' -o -path '*/images/*' \) \
        -printf '%T@ %s %p\n' 2>/dev/null | sort -rn | head -100 | \
        $_AWK '{printf "%s %s %s\n", strftime("%Y-%m-%d %H:%M:%S", $1), $2, $3}'
    echo "\`\`\`"

    echo "### D. Malware Signatures (Webshells/Obfuscation)"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f -name '*.php' ${OWNER_FILTER[@]+"${OWNER_FILTER[@]}"} -print0 2>/dev/null | \
        xargs -0 grep -lE '(eval\s*\(\s*(base64_decode|gzinflate|gzuncompress|str_rot13)|c99shell|r57shell|WSO|FilesMan|b374k|phpspy|shell_exec\s*\()' \
        2>/dev/null | head -100 || echo "No signatures found"
    echo "\`\`\`"

    echo "### E. Cloaked Images (PHP inside JPG/PNG)"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 8 -type f \
        \( -iname '*.jpg' -o -iname '*.png' -o -iname '*.gif' -o -iname '*.ico' \) \
        -print0 2>/dev/null | xargs -0 grep -rlP '<\?php|<\?=|<\?\s' 2>/dev/null | head -50 || echo "None found"
    echo "\`\`\`"

    echo "### F. Root-Owned Files in User Home (Rootkit Indicator)"
    echo "\`\`\`text"
    if [[ -n "$OWNER" && -n "$HOMEDIR" ]]; then
        find "$HOMEDIR" -maxdepth 8 -user root -type f ! -path '*/.cpanel/*' ! -path '*/.cagefs/*' \
            -printf '%T@ %p\n' 2>/dev/null | head -50
    else
        find "${SCAN_DIRS[@]}" -maxdepth 6 -user root -type f ! -path '*/.cpanel/*' ! -path '*/.cagefs/*' \
            -printf '%T@ %p\n' 2>/dev/null | head -50
    fi
    echo "\`\`\`"

    echo "### G. World Writable Files"
    echo "\`\`\`text"
    find "${SCAN_DIRS[@]}" -maxdepth 6 -perm -o+w -type f ! -path '*/tmp/*' ! -path '*/cache/*' \
        -printf '%m %p\n' 2>/dev/null | head -50
    echo "\`\`\`"

else
    echo "No directories found to scan."
fi
echo ""
fi

# --- Imunify DB ---
if _run_section "imunify_db"; then
echo "## 5. Imunify Databases"
echo "\`\`\`text"
SQLITE="/opt/alt/sqlite/usr/bin/sqlite3"
RESDB="/var/imunify360/imunify360-resident.db"
MAINDB="/var/imunify360/imunify360.db"
if [[ -x "$SQLITE" ]]; then
    echo "--- Recent Incidents ---"
    echo "select * from incident order by timestamp desc limit 20;" | "$SQLITE" "$RESDB" 2>/dev/null || echo "Unavailable"
    echo "--- Malware Hits ---"
    echo "select * from malware_hits limit 20;" | "$SQLITE" "$MAINDB" 2>/dev/null || echo "Unavailable"
else
    echo "sqlite3 not found"
fi
echo "\`\`\`"
echo ""
fi

# --- Network & Memory ---
if _run_section "network"; then
echo "## 6. Network & Process Forensics"
echo "\`\`\`text"
echo "--- Outbound Connections ---"
ss -tunp 2>/dev/null | grep ESTAB | grep -v '127.0.0.1' | head -50
echo "--- Suspicious Processes ---"
ps aux 2>/dev/null | grep -iE 'perl|python|wget|curl|minerd|xmrig' | grep -v grep | head -20
echo "--- Deleted Binaries in Memory ---"
for pid_dir in /proc/[0-9]*; do
    pid="${pid_dir##*/}"; exe_link=$(readlink "${pid_dir}/exe" 2>/dev/null || echo "")
    if [[ "$exe_link" == *"(deleted)"* ]]; then
        cmd=$(tr '\0' ' ' < "${pid_dir}/cmdline" 2>/dev/null | head -c 200 || echo "")
        echo "PID: $pid | Exe: $exe_link | Cmd: $cmd"
    fi
done 2>/dev/null
echo "\`\`\`"
echo ""
fi

# --- Logs ---
if _run_section "logs"; then
echo "## 7. Logs"
grep_pattern=""
if [[ -n "$TARGET_DOMAINS" ]]; then
    grep_pattern="${TARGET_DOMAINS//,/|}"
    echo "> **Filtering Logs for:** \`$grep_pattern\`"
fi

for logfile in \
    /var/log/imunify360/console.log \
    /usr/local/apache/logs/error_log \
    /usr/local/apache/logs/access_log \
    /var/log/nginx/error.log \
    /var/log/nginx/access.log \
    /var/www/vhosts/system/*/logs/error_log; do
    
    [[ -f "$logfile" ]] || continue
    echo "### File: $logfile"
    echo "\`\`\`text"
    if [[ -n "$grep_pattern" ]]; then
        grep -E "$grep_pattern" "$logfile" 2>/dev/null | tail -n 50 || echo "No matches"
    else
        tail -n 50 "$logfile" 2>/dev/null
    fi
    echo "\`\`\`"
done
echo ""
fi

# ============================================================================
# 4. JSON SUMMARY
# ============================================================================
echo "## 8. Target Summary (JSON)"
echo "\`\`\`json"
echo "["

if [[ -n "$TARGET_DOMAINS" ]]; then
    IFS=',' read -ra DOM_ARRAY <<< "$TARGET_DOMAINS"
    count=${#DOM_ARRAY[@]}
    i=0
    
    for d in "${DOM_ARRAY[@]}"; do
        d=$(echo "$d" | xargs)
        docroot=$(resolve_docroot "$d")
        
        if [[ "$docroot" == "NOT_FOUND" ]]; then
            app_type="Path not found"
            nested="[]"
        else
            app_type=$(detect_cms "$docroot")
            # This variable now correctly holds data due to the subshell fix
            nested_raw=$(scan_nested_apps_json "$docroot")
            if [[ -z "$nested_raw" ]]; then nested="[]"; else nested="[ $nested_raw ]"; fi
        fi
        
        # Output JSON Object
        echo "  {"
        echo "    \"domain\": \"$d\","
        echo "    \"application\": \"$app_type\","
        echo "    \"root\": \"$docroot\","
        echo "    \"nested_apps\": $nested"
        
        i=$((i+1))
        if [[ $i -lt $count ]]; then echo "  },"; else echo "  }"; fi
    done
fi

echo "]"
echo "\`\`\`"

echo ""
echo "**End of Forensic Report**"
